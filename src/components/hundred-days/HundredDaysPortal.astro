    summaryEn: "Research advances from event headlines into execution windows, liquidity, index paths, triggers, and revision.",
    steps: [
      { date: "05-30", labelZh: "统一 MSCI 执行与流动性口径", labelEn: "Reconcile MSCI execution and liquidity", href: "/investor/reports/recap-msci-rebalance-reconciliation-report-2026-05-30.zh/" },
      { date: "06-01", labelZh: "科创 50 首次市场表现复盘", labelEn: "First STAR 50 market-path recap", href: "/investor/reports/recap-kc50-recap-2026-06-01/" },
      { date: "LIVE", labelZh: "继续跟踪科创 50 论点", labelEn: "Continue the STAR 50 thesis", href: "/investor/theses/thesis-8525fc93df/" },
    ],
  },
];

const revisionLedger = [
  {
