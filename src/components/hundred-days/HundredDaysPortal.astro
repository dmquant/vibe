  { key: "reports", label: "Published research", labelZh: "公开研究", color: "blue", href: "/investor/archive/" },
  { key: "researchThreads", label: "Research discussions", labelZh: "研究讨论", color: "green", href: "/investor/timeline/" },
  { key: "researchNotes", label: "Evidence events", labelZh: "证据事件", color: "yellow", href: "/investor/timeline/" },
  { key: "theses", label: "Living theses", labelZh: "动态论点", color: "orange", href: "/investor/theses/" },
  { key: "lanes", label: "Investable lanes", labelZh: "投资赛道", color: "blue", href: "/investor/lanes/" },
  { key: "stocks", label: "Stock nodes", labelZh: "股票节点", color: "green", href: "/investor/stocks/" },
