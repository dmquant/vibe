---
const { dashboard } = Astro.props;

const dashboardHref = dashboard.links?.dashboard || "/investor/daily/";
const hrefWithAnchor = (anchor) => `${dashboardHref}${dashboardHref.includes("#") ? "" : `#${anchor}`}`;
const publicDailyHref = (href, fallback = dashboardHref) => {
  if (!href) return fallback;
  const value = String(href);
  if (/^\/blog\/(?:brief-daily|editor-daily|mailbox-digest)-/.test(value)) return fallback;
  return value;
};
const sectionHref = hrefWithAnchor("daily-dashboard-sections");
const editorHref = hrefWithAnchor("daily-dashboard-editor");
const researchHref = hrefWithAnchor("daily-dashboard-research");
const mailboxHref = publicDailyHref(dashboard.links?.mailboxZh, "/investor/#operations");
const readerReport = dashboard.readerReport || null;
const readerHref = publicDailyHref(readerReport?.href, "/investor/reports/");

const quoteGroups = ["Equity", "Rates/Risk", "Commodities", "FX"];
const quotesByGroup = quoteGroups.map((group) => ({
  group,
  items: (dashboard.marketQuotes || []).filter((quote) => quote.group === group).slice(0, 6),
}));

const directionFor = (item) => {
  const text = `${item.value || ""} ${item.change || ""}`;
  if (text.includes("-")) return "down";
  if (text.includes("+")) return "up";
  return "flat";
};

const mapCoordinates = {
  "宏观通胀传导": [39.5, -98.35],
  "AI 基础设施": [37.34, -121.89],
  "工业供给瓶颈": [31.23, 121.47],
  "电力与电网": [52.52, 13.4],
  "半导体与存储": [24.8, 120.99],
  "消费与生产率": [35.68, 139.76],
};
const fallbackCoordinates = [[51.5, -0.1], [1.35, 103.82], [19.07, 72.88], [-33.86, 151.21]];
const accents = ["#2f80ed", "#169b62", "#d64545", "#d7a316", "#e46f2e"];
const mapItems = (dashboard.chainRadar || []).map((item, index) => ({
  label: item.label,
  heat: item.heat,
  latest: item.latest,
  recent: item.recent,
  risk: item.risk,
  href: publicDailyHref(item.href, "/investor/#dailyReports"),
  evidenceTitle: item.evidenceTitle || "",
  coords: mapCoordinates[item.label] || fallbackCoordinates[index % fallbackCoordinates.length],
  accent: accents[index % accents.length],
}));
const serializedMapData = JSON.stringify(mapItems).replaceAll("<", "\\u003c");
const isAhead = dashboard.status === "morning_manifest_ahead_of_investor_daily";
---

<main class="daily-dashboard-page">
  <header class="daily-dashboard-hero">
    <div>
      <div class="daily-dashboard-kicker">AI Institute · Morning Brief Dashboard</div>
      <h1>{dashboard.summary?.headline || "晨会信号看板"}</h1>
      <p>{dashboard.summary?.lead || "晨会结果已整理为市场报价、核心结论、编辑冲突和深度研究入口。"}</p>
    </div>
    <div class="daily-dashboard-status">
      <span>{dashboard.date || "Latest"}</span>
      <strong>{isAhead ? "晨会结果领先投资台" : "投资台已同步"}</strong>
      {isAhead ? <em>Investor daily: {dashboard.investorDailyDate}</em> : null}
    </div>
  </header>

  <section class="daily-dashboard-actions" aria-label="Morning brief links">
    <a href={sectionHref}>中文晨会简报</a>
    <a href={editorHref}>总编报告</a>
    <a href={mailboxHref}>邮箱摘要</a>
    {readerReport ? <a href={readerHref}>读者报告</a> : null}
    <a href={dashboard.links?.investorShell || "/investor/#daily"}>投资台交互版</a>
    {dashboard.links?.docx ? <a href={dashboard.links.docx}>下载 DOCX</a> : null}
  </section>

  <section class="daily-dashboard-metrics">
    <a href={sectionHref}>
      <span>晨会板块</span>
      <strong>{dashboard.stats?.sections || 0}</strong>
    </a>
    <a href={researchHref}>
      <span>深度研究</span>
      <strong>{dashboard.stats?.deepResearch || 0}</strong>
    </a>
    <a href={mailboxHref}>
      <span>跨部门传递</span>
      <strong>{dashboard.stats?.handoffs || 0}</strong>
    </a>
    <a href="#daily-dashboard-market">
      <span>市场报价</span>
      <strong>{dashboard.stats?.marketQuotes || 0}</strong>
    </a>
  </section>

  <section class="daily-dashboard-grid">
    <section class="daily-dashboard-panel daily-dashboard-market" id="daily-dashboard-market">
      <div class="daily-dashboard-panel-head">
        <h2>市场报价与约束</h2>
        <span>Market Tape</span>
      </div>
      <div class="daily-market-groups">
        {quotesByGroup.map(({ group, items }) => (
          <article class="daily-market-group">
            <h3>{group}</h3>
            <div>
              {items.length ? items.map((item) => (
                <a class={`daily-quote ${directionFor(item)}`} href={publicDailyHref(item.href, sectionHref)}>
                  <span>{item.labelZh || item.key}</span>
                  <strong>{item.value}</strong>
                  <em>{item.change || "latest"}</em>
                </a>
              )) : <p>暂无数据</p>}
            </div>
          </article>
        ))}
      </div>
    </section>

    {readerReport ? (
      <section class="daily-dashboard-panel daily-dashboard-wide daily-reader-report-panel" id="daily-dashboard-reader-report">
        <div class="daily-dashboard-panel-head">
          <h2>读者报告</h2>
          <span>Reader Memo</span>
        </div>
        <a class="daily-reader-report-lead" href={readerHref}>
          <span>{readerReport.date || dashboard.date || "Latest"}</span>
          <strong>{readerReport.title}</strong>
          <em>{readerReport.summary}</em>
        </a>
        <div class="daily-reader-priority-grid">
          {(readerReport.priorityViews || []).map((item, index) => (
            <a href={readerHref} style={`--accent:${accents[index % accents.length]}`}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{item.title}</strong>
              <em>{item.view}</em>
            </a>
          ))}
        </div>
      </section>
    ) : null}

    <section class="daily-dashboard-panel" id="daily-dashboard-sections">
      <div class="daily-dashboard-panel-head">
        <h2>晨会板块</h2>
        <span>Sections</span>
      </div>
      <div class="daily-section-list">
        {(dashboard.morningSections || []).map((item, index) => (
          <a id={`daily-dashboard-section-${index + 1}`} href={publicDailyHref(item.href, sectionHref)}>
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <em>{item.detail}</em>
          </a>
        ))}
      </div>
    </section>

    <section class="daily-dashboard-panel daily-dashboard-map-panel">
      <div class="daily-dashboard-panel-head">
        <h2>研究链地图</h2>
        <span>Chain Radar</span>
      </div>
      <div id="dailyDashboardMap" class="daily-dashboard-map" aria-label="Research-chain map"></div>
      <div class="daily-map-tags">
        {mapItems.map((item) => (
          <a href={item.href} style={`--accent:${item.accent}`}>{item.label}</a>
        ))}
      </div>
    </section>

    <section class="daily-dashboard-panel" id="daily-dashboard-editor">
      <div class="daily-dashboard-panel-head">
        <h2>总编冲突图</h2>
        <span>Editor Signals</span>
      </div>
      <div class="daily-editor-list">
        {(dashboard.editorSignals || []).map((item, index) => (
          <a id={`daily-dashboard-editor-${index + 1}`} href={publicDailyHref(item.href, editorHref)}>
            <span>{item.priority}</span>
            <strong>{item.title}</strong>
            <em>{item.conclusion}</em>
          </a>
        ))}
      </div>
    </section>

    <section class="daily-dashboard-panel daily-dashboard-wide" id="daily-dashboard-research">
      <div class="daily-dashboard-panel-head">
        <h2>深度研究入口</h2>
        <span>Research Handoffs</span>
      </div>
      <div class="daily-research-list">
        {(dashboard.deepResearch || []).map((item, index) => (
          <a id={`daily-dashboard-research-${index + 1}`} href={publicDailyHref(item.href, researchHref)}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="daily-dashboard-panel">
      <div class="daily-dashboard-panel-head">
        <h2>发布状态</h2>
        <span>Publisher State</span>
      </div>
      <div class="daily-state-list">
        <div><span>Image prompts</span><strong>{dashboard.assets?.promptsReady ? "Ready" : "Missing"}</strong></div>
        <div><span>Images published</span><strong>{dashboard.assets?.imagesPublished ? "Yes" : "No"}</strong></div>
        <div><span>Investor reports</span><strong>{dashboard.relatedCounts?.investorDailyReports || 0}</strong></div>
        <div><span>Evidence table</span><strong>{dashboard.relatedCounts?.investorTableReports || 0}</strong></div>
      </div>
      <p>{dashboard.summary?.privacyNote}</p>
    </section>
  </section>
</main>

<script id="daily-dashboard-map-data" type="application/json" is:inline set:html={serializedMapData}></script>
<script>
  import "../../scripts/daily-dashboard-map.js";
</script>
