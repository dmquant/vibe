---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="nav-left">
			<a href="/" class="logo">
				<span class="logo-icon">◆</span>
				<span class="logo-text">{SITE_TITLE}</span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Articles</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="nav-right">
			<button id="lang-toggle" class="lang-toggle" aria-label="Toggle language">
				<span class="lang-option" data-lang="en">EN</span>
				<span class="lang-divider">/</span>
				<span class="lang-option" data-lang="zh">中文</span>
			</button>
			<a href="https://github.com/dmquant/vibe" target="_blank" aria-label="GitHub" class="github-link">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>

<script>
	function initLang() {
		const saved = localStorage.getItem('researchos-lang') || 'en';
		document.documentElement.setAttribute('data-lang', saved);
		updateToggle(saved);
	}

	function updateToggle(lang: string) {
		document.querySelectorAll('.lang-option').forEach(el => {
			el.classList.toggle('active', (el as HTMLElement).dataset.lang === lang);
		});
	}

	document.getElementById('lang-toggle')?.addEventListener('click', () => {
		const current = document.documentElement.getAttribute('data-lang') || 'en';
		const next = current === 'en' ? 'zh' : 'en';
		localStorage.setItem('researchos-lang', next);
		document.documentElement.setAttribute('data-lang', next);
		updateToggle(next);
		// Dispatch custom event for page-level reactivity
		window.dispatchEvent(new CustomEvent('lang-change', { detail: { lang: next } }));
	});

	initLang();
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0 1.5rem;
		background: rgba(13, 17, 23, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border, #30363d);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		height: 56px;
	}
	.nav-left { display: flex; align-items: center; }
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--text-primary, #e6edf3);
		font-weight: 700;
		font-size: 1.1rem;
	}
	.logo-icon { color: var(--accent-cyan, #58a6ff); font-size: 1.2rem; }
	.internal-links { display: flex; gap: 0.25rem; }
	nav a {
		padding: 0.5em 0.75em;
		color: var(--text-secondary, #8b949e);
		text-decoration: none;
		font-size: 0.9rem;
		border-radius: 6px;
		transition: all 0.2s;
	}
	nav a:hover, nav a.active {
		color: var(--text-primary, #e6edf3);
		background: rgba(88, 166, 255, 0.08);
	}
	.nav-right { display: flex; align-items: center; gap: 0.75rem; }
	.lang-toggle {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.3rem 0.65rem;
		background: var(--bg-surface, #161b22);
		border: 1px solid var(--border, #30363d);
		border-radius: 6px;
		cursor: pointer;
		font-size: 0.78rem;
		font-family: var(--font-ui, 'Inter', sans-serif);
		transition: border-color 0.2s;
	}
	.lang-toggle:hover { border-color: var(--accent-cyan, #58a6ff); }
	.lang-option {
		color: var(--text-muted, #484f58);
		transition: color 0.2s;
		font-weight: 500;
	}
	.lang-option.active { color: var(--accent-cyan, #58a6ff); font-weight: 600; }
	.lang-divider { color: var(--text-muted, #484f58); }
	.github-link {
		display: flex;
		padding: 0.35em;
		color: var(--text-secondary, #8b949e);
	}
	.github-link:hover { color: var(--text-primary, #e6edf3); }
	@media (max-width: 720px) {
		.github-link { display: none; }
	}
</style>
