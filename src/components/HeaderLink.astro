---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '') || '/';
const normalizedHref = String(href || '/').replace(/\/$/, '') || '/';
let isActive = pathname === normalizedHref;
if (normalizedHref !== '/' && normalizedHref !== '/investor') {
	isActive = isActive || pathname.startsWith(`${normalizedHref}/`);
}
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
