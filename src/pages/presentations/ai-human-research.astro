---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { readSiteData } from '../../lib/investor-generated.js';

const siteData = readSiteData();
const stats = siteData.stats || {};
const dailyBrief = siteData.dailyBrief || {};
const dailyStats = dailyBrief.stats || {};
const synthesis = dailyBrief.synthesis || {};
const deepResearch = siteData.deepResearch || [];
const themes = siteData.themes || [];
const topViews = siteData.topViews || [];
const changeRadar = siteData.changeRadar || {};
const chainRadar = dailyBrief.chainRadar || changeRadar.chainSignals || [];
const highlights = (dailyBrief.highlights || []).slice(0, 4);
const risks = (dailyBrief.riskMatrix || changeRadar.riskAlerts || []).slice(0, 4);
const marketTape = (dailyBrief.marketTape?.zh || []).slice(0, 8);

const formatNumber = (value) => new Intl.NumberFormat('zh-CN').format(Number(value || 0));
const pct = (value, max) => Math.max(7, Math.round((Number(value || 0) / Number(max || 1)) * 100));

const findDeep = (topicId) => deepResearch.find((item) => item.topic_id === topicId) || null;
const aiPower = findDeep('ai-power-inflation-transmission');
const powerHardware = findDeep('transformer-goes-copper-bottleneck');
const productivity = findDeep('ai-productivity-disinflation-timing');
const mag7 = findDeep('mag7-next-era-losers');
const chinaPower = findDeep('china-power-equipment-export-policy');

const deepLinks = [aiPower, powerHardware, productivity, mag7, chinaPower].filter(Boolean);
const maxThemeValue = Math.max(...themes.map((item) => Number(item.value || 0)), 1);
const selectedThemes = themes
	.filter((item) => ['AI 资本开支需求', '电力与电网瓶颈', '供应链与地缘政治', '研究质检与自我修正', '生产率与效率'].includes(item.label))
	.slice(0, 5);

const heroStats = [
	{ label: 'AI 分析师', value: stats.analysts || siteData.analysts?.length || 0, suffix: '位', href: '/investor/#analysts' },
	{ label: '证据报告', value: stats.reports || siteData.reports?.length || 0, suffix: '篇', href: '/investor/#dailyReports' },
	{ label: '知识节点', value: stats.knowledge_nodes || 0, suffix: '个', href: '/investor/#knowledgeGraph' },
	{ label: '图谱边', value: stats.knowledge_edges || 0, suffix: '条', href: '/investor/#knowledgeGraph' },
];

const workflowSteps = [
	{
		kicker: '01',
		title: '多角色并行采集',
		text: '行业、宏观、策略、风控和编审角色同时工作，先把原始问题拆成可验证的小问题。',
		href: '/screenshots/ai_institute/chinese/analysts.png',
	},
	{
		kicker: '02',
		title: '白板互相挑战',
		text: '白板不是单人笔记，而是支持、反驳、压力测试和终审逐层叠加的研究现场。',
		href: '/screenshots/ai_institute/chinese/whiteboard.png',
	},
	{
		kicker: '03',
		title: '证据归档与图谱化',
		text: '报告被归入主题、产业链和风险矩阵，方便人类研究员回溯证据，而不是只看摘要。',
		href: '/investor/#knowledgeGraph',
	},
	{
		kicker: '04',
		title: '静态站点发布',
		text: 'Vibe 只承载可公开发布的静态成果，前端展示与 API 抓取、密钥、维护脚本解耦。',
		href: '/investor/',
	},
];

const infraCases = [
	{
		id: 'power',
		accent: 'red',
		title: '算力先遇到电力墙',
		metric: `${formatNumber(dailyStats.reports)} 篇晨会材料`,
		body: '5 月 26 日晨会把“变压器与液冷供应链对 AI 基础设施的约束”列为高影响、高概率风险。更早的白板研究也把 AI power 从公用事业泡沫改写为“可交付 firm MW + 并网 + 合同”的物理经营许可。',
		link: powerHardware?.href || aiPower?.href || '/investor/#deep',
		linkLabel: '看电力硬件深研',
	},
	{
		id: 'memory',
		accent: 'blue',
		title: '推理扩展抬升 HBM 强度',
		metric: '260-300GB / GPU 等效',
		body: '旧白板中对推理规模法则的判断很清晰：推理任务变长、KV cache 变大、带宽要求上升，HBM4、CoWoS、基板和测试时间成为系统瓶颈。AI 需要进化，必须先有稳定、可扩展的内存和封装环境。',
		link: aiPower?.href || '/investor/#deep',
		linkLabel: '看 AI 算力深研',
	},
	{
		id: 'optical',
		accent: 'green',
		title: '光互联把租金推向上游',
		metric: '800G / 1.6T',
		body: 'CPO 与光模块不是孤立热点。早期白板把 800G、1.6T、InP、EML、高端光材料与 HBM 封装耗材放到同一张物理 AI 地图里，提醒人类研究员寻找真正稀缺的利润池。',
		link: '/investor/#deep',
		linkLabel: '看深研目录',
	},
	{
		id: 'equipment',
		accent: 'orange',
		title: '电力设备决定部署速度',
		metric: 'GOES / 铜 / 变压器',
		body: '变压器、取向硅钢、铜缆、开关设备和燃机交付周期，把抽象的 AI 资本开支变成可以验证的时间表。AI Institute 的研究把这些约束放入风险矩阵，避免把“AI beta”误读为所有环节都受益。',
		link: chinaPower?.href || powerHardware?.href || '/investor/#deep',
		linkLabel: '看设备出海深研',
	},
];

const decisionExamples = [
	...(synthesis.bullets || []).slice(0, 3),
	...highlights.slice(0, 2).map((item) => ({
		label: item.primary_chain || '证据报告',
		text: item.title,
		href: item.href,
	})),
].filter((item) => item?.text);

const imagePanels = [
	{
		id: 'daily',
		label: '晨会仪表盘',
		src: '/investor-assets/daily/daily-brief-2026-05-26-web-summary.png',
		href: '/investor/#daily',
		caption: '晨会把当日主题、风险、市场价格和证据链接压缩为可执行看板。',
	},
	{
		id: 'heatmap',
		label: '风险热力图',
		src: '/investor-assets/daily/daily-brief-2026-05-26-web-heatmap.png',
		href: '/investor/#daily',
		caption: '风险热力图把“哪里可能错”前置给人类决策者。',
	},
	{
		id: 'funnel',
		label: '语料漏斗',
		src: '/investor-assets/charts/corpus_funnel.png',
		href: '/investor/#method',
		caption: '语料漏斗展示从原始材料到可发布研究的过滤过程。',
	},
	{
		id: 'map',
		label: '传导通道',
		src: '/investor-assets/charts/channel_map.png',
		href: '/investor/#knowledgeGraph',
		caption: '传导图把主题、风险与产业链连接起来，帮助研究员追溯因果链。',
	},
];

const marketParser = (line) => {
	const text = String(line || '').replace(/\s+/g, ' ').trim();
	const match = text.match(/^(.+?)\s+([~]?[0-9][0-9,]*(?:\.[0-9]+)?(?:\s*(?:USD\/bbl|USD\/oz|%))?)(?:\s+\((.*)\))?$/);
	const change = match?.[3] || '';
	return {
		label: match?.[1] || text,
		value: match?.[2] || '',
		change,
		direction: change.includes('-') ? 'down' : change ? 'up' : 'flat',
	};
};
const marketRows = marketTape.map(marketParser);
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
	<head>
		<BaseHead
			title="AI如何与人类研究员并行"
			description="一份基于 AI Institute 实证材料的互动式中文演示：AI 需要算力与环境进化，也能成为金融投资研究的人类伙伴。"
		/>
	</head>
	<body>
		<Header />
		<div class="deck-progress" aria-hidden="true"></div>
		<main class="presentation-shell">
			<nav class="deck-rail" aria-label="演示章节">
				<a href="#opening" class="rail-link active"><span>01</span>开场</a>
				<a href="#institute" class="rail-link"><span>02</span>研究院</a>
				<a href="#compute" class="rail-link"><span>03</span>算力环境</a>
				<a href="#decision" class="rail-link"><span>04</span>投资决策</a>
				<a href="#parallel" class="rail-link"><span>05</span>并行伙伴</a>
				<a href="#closing" class="rail-link"><span>06</span>收束</a>
			</nav>

			<div class="deck-content">
				<section class="slide hero-slide reveal" id="opening">
					<div class="hero-copy">
						<p class="eyebrow">ResearchOS / AI Institute Presentation</p>
						<h1>AI如何与人类研究员并行</h1>
						<p class="hero-thesis">
							AI 不应该被理解为替代人类工作的威胁。更准确的定位是：在充足算力、合适环境和可审计证据链之上，AI 成为人类研究员的并行伙伴，帮助我们把金融投资决策从“信息不足”推进到“证据充分但仍由人负责”。
						</p>
						<div class="hero-actions">
							<a href="#compute" class="primary-action">看核心论点</a>
							<a href="/investor/" class="secondary-action">打开 AI 股票研究院</a>
						</div>
					</div>
					<div class="hero-visual" aria-label="AI Institute 项目界面">
						<a href="/screenshots/ai_institute/chinese/dashboard.png" class="screen-frame primary-screen">
							<img src="/screenshots/ai_institute/chinese/dashboard.png" alt="AI Institute 中文仪表盘截图" loading="eager" />
						</a>
						<a href="/screenshots/ai_institute/chinese/whiteboard.png" class="screen-frame secondary-screen">
							<img src="/screenshots/ai_institute/chinese/whiteboard.png" alt="AI Institute 白板研究截图" loading="eager" />
						</a>
					</div>
				</section>

				<section class="slide reveal" id="institute">
					<div class="section-kicker">Part 1 / 项目介绍</div>
					<div class="split-heading">
						<h2>AI 股票研究院：一个可发布、可回溯、可协作的研究系统</h2>
						<p>
							AI Institute 在后台负责采集、研究、反驳、合成和质检；Vibe 只发布静态网站成果。这个边界很重要：研究系统可以持续演化，公开网站保持轻量、稳定、可审计。
						</p>
					</div>

					<div class="metric-grid">
						{heroStats.map((item) => (
							<a href={item.href} class="metric-tile">
								<span class="metric-label">{item.label}</span>
								<strong><span class="count-up" data-target={item.value}>0</span>{item.suffix}</strong>
								<small>点击查看来源模块</small>
							</a>
						))}
					</div>

					<div class="workflow-grid">
						{workflowSteps.map((step) => (
							<a href={step.href} class="workflow-step">
								<span>{step.kicker}</span>
								<h3>{step.title}</h3>
								<p>{step.text}</p>
							</a>
						))}
					</div>
				</section>

				<section class="slide reveal" id="compute">
					<div class="section-kicker">Core 1 / 算力与环境</div>
					<div class="split-heading">
						<h2>AI 要进化，先要有足够算力和合适环境</h2>
						<p>
							从旧白板到深度研究，AI Institute 的共同结论不是“买所有 AI”，而是更工程化：真实瓶颈正在从 GPU 口号迁移到 firm power、HBM、先进封装、光互联、冷却和电力设备。
						</p>
					</div>

					<div class="infra-stage">
						<div class="infra-map" aria-label="AI 基础设施四层约束">
							{infraCases.map((item, index) => (
								<button
									class={`infra-node accent-${item.accent}${index === 0 ? ' active' : ''}`}
									data-title={item.title}
									data-metric={item.metric}
									data-body={item.body}
									data-link={item.link}
									data-link-label={item.linkLabel}
									type="button"
								>
									<span class="node-index">0{index + 1}</span>
									<strong>{item.title}</strong>
									<small>{item.metric}</small>
								</button>
							))}
						</div>
						<div class="infra-detail" id="infraDetail">
							<span class="detail-kicker">点击左侧节点切换</span>
							<h3>{infraCases[0].title}</h3>
							<strong>{infraCases[0].metric}</strong>
							<p>{infraCases[0].body}</p>
							<a href={infraCases[0].link}>{infraCases[0].linkLabel}</a>
						</div>
					</div>

					<div class="theme-bars" aria-label="主题强度条形图">
						{selectedThemes.map((item) => (
							<a href="/investor/#themes" class="theme-bar">
								<span>{item.label}</span>
								<div class="bar-track"><i style={`--bar:${pct(item.value, maxThemeValue)}%`}></i></div>
								<strong>{formatNumber(item.value)}</strong>
							</a>
						))}
					</div>
				</section>

				<section class="slide reveal" id="decision">
					<div class="section-kicker">Core 2 / 投资决策支持</div>
					<div class="split-heading">
						<h2>AI 的产出不是代替拍板，而是让人类决策更有证据</h2>
						<p>
							金融投资需要速度，也需要责任。AI Institute 把晨会、风险矩阵、深研、价格板和证据链接组织成一个决策支持系统；人类仍然负责仓位、风控、合规和最终判断。
						</p>
					</div>

					<div class="decision-layout">
						<div class="decision-feed">
							<div class="feed-header">
								<span>{dailyBrief.date || 'Latest'}</span>
								<strong>{synthesis.headline || '晨会综合判断'}</strong>
							</div>
							<div class="market-strip" aria-label="市场价格带">
								{marketRows.map((row) => (
									<a href="/investor/#daily" class={`market-pill ${row.direction}`}>
										<span>{row.label}</span>
										<strong>{row.value}</strong>
										<small>{row.change || 'latest'}</small>
									</a>
								))}
							</div>
							<div class="decision-list">
								{decisionExamples.map((item) => (
									<a href={item.href || '/investor/#daily'} class="decision-item">
										<span>{item.label}</span>
										<p>{item.text}</p>
									</a>
								))}
							</div>
						</div>

						<div class="asset-browser" id="assetBrowser">
							<div class="asset-tabs">
								{imagePanels.map((panel, index) => (
									<button
										type="button"
										class={index === 0 ? 'active' : ''}
										data-src={panel.src}
										data-href={panel.href}
										data-caption={panel.caption}
									>
										{panel.label}
									</button>
								))}
							</div>
							<a href={imagePanels[0].href} class="asset-image-link" id="assetImageLink">
								<img src={imagePanels[0].src} alt="AI Institute 可视化成果" id="assetImage" loading="lazy" />
							</a>
							<p id="assetCaption">{imagePanels[0].caption}</p>
						</div>
					</div>

					<div class="deep-grid">
						{deepLinks.map((item) => (
							<a href={item.href} class="deep-link">
								<span>{item.date}</span>
								<h3>{item.title_zh}</h3>
								<p>{item.summary_zh}</p>
								<small>{item.evidence_count} 条证据 / {item.risk_count} 个风险 / {item.analyst_count} 位分析师</small>
							</a>
						))}
					</div>
				</section>

				<section class="slide reveal" id="parallel">
					<div class="section-kicker">Core 3 / 并行伙伴</div>
					<div class="split-heading">
						<h2>人和 AI 分工，不是人被 AI 吞掉</h2>
						<p>
							AI 可以高频读取、交叉验证、生成反例和持续更新；人类研究员更适合设定问题、识别语境、权衡风险预算、决定是否行动。真正有价值的是并行，而不是替代。
						</p>
					</div>

					<div class="parallel-board">
						<div class="mode-switch" role="tablist" aria-label="并行模式">
							<button class="active" type="button" data-mode="research">研究</button>
							<button type="button" data-mode="risk">风控</button>
							<button type="button" data-mode="portfolio">组合</button>
						</div>
						<div class="mode-panels">
							<div class="mode-panel active" data-panel="research">
								<h3>AI 做高频证据工作，人做问题定义</h3>
								<p>AI 把白板、报告、晨会、图谱和价格板持续串起来；人类研究员决定哪些问题值得问、哪些证据足够强、哪些结论必须推翻重做。</p>
							</div>
							<div class="mode-panel" data-panel="risk">
								<h3>AI 暴露约束，人负责容错边界</h3>
								<p>AI 可以把变压器、GOES、铜、HBM、CPO、并网和融资约束提前列入风险矩阵；人类仍然负责设定亏损边界、流动性约束和不交易的条件。</p>
							</div>
							<div class="mode-panel" data-panel="portfolio">
								<h3>AI 给出备选表达，人负责最终配置</h3>
								<p>AI 能提出“物理 AI 栈”而不是“泛 AI beta”的表达方式；人类根据估值、拥挤度、时间窗口和客户约束决定是否持有、对冲或等待。</p>
							</div>
						</div>
						<div class="parallel-columns">
							<div>
								<span>AI 伙伴负责</span>
								<ul>
									<li>持续扫描 3,000+ 份研究材料</li>
									<li>把同一主题的支持与反驳并列</li>
									<li>把风险、价格和产业链证据结构化</li>
									<li>生成晨会、深研和可视化仪表盘</li>
								</ul>
							</div>
							<div>
								<span>人类研究员负责</span>
								<ul>
									<li>确定研究议题和投资约束</li>
									<li>判断证据质量和可交易性</li>
									<li>管理仓位、回撤和合规责任</li>
									<li>在不确定性中承担最终决策</li>
								</ul>
							</div>
						</div>
					</div>
				</section>

				<section class="slide reveal" id="closing">
					<div class="section-kicker">Closing / 结论</div>
					<h2>AI 是研究员的第二操作系统，不是人类判断的替代品</h2>
					<div class="closing-grid">
						<a href={aiPower?.href || '/investor/#deep'} class="closing-card">
							<span>01</span>
							<strong>先建设环境</strong>
							<p>算力、电力、内存、封装、光互联、冷却和工作流环境，是 AI 能进化的基础设施。</p>
						</a>
						<a href="/investor/#daily" class="closing-card">
							<span>02</span>
							<strong>再输出证据</strong>
							<p>晨会、风险矩阵和深研让投资决策有据可查，而不是让人类简单服从模型答案。</p>
						</a>
						<a href={mag7?.href || '/investor/#deep'} class="closing-card">
							<span>03</span>
							<strong>最终由人负责</strong>
							<p>AI 提供速度、广度和反例；人类保留目标设定、风险承担和价值判断。</p>
						</a>
					</div>
					<div class="closing-quote">
						<p>“并行”的含义不是把研究员从流程中移除，而是把研究员从重复搬运信息中释放出来，让其专注于判断、责任和创造。</p>
					</div>
				</section>
			</div>
		</main>
		<Footer />

		<script>
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const progress = document.querySelector('.deck-progress');
			const railLinks = Array.from(document.querySelectorAll('.rail-link'));
			const sections = Array.from(document.querySelectorAll('.slide'));

			function updateProgress() {
				const max = document.documentElement.scrollHeight - window.innerHeight;
				const value = max > 0 ? (window.scrollY / max) * 100 : 0;
				if (progress) progress.style.width = `${value}%`;
			}

			window.addEventListener('scroll', updateProgress, { passive: true });
			updateProgress();

			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) entry.target.classList.add('is-visible');
				});
			}, { threshold: 0.16 });

			document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

			const sectionObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					railLinks.forEach((link) => link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`));
				});
			}, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });

			sections.forEach((section) => sectionObserver.observe(section));

			const countObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting || entry.target.dataset.done === 'true') return;
					entry.target.dataset.done = 'true';
					const target = Number(entry.target.dataset.target || 0);
					const duration = reduceMotion ? 0 : 900;
					const started = performance.now();

					function tick(now) {
						const t = duration === 0 ? 1 : Math.min(1, (now - started) / duration);
						const eased = 1 - Math.pow(1 - t, 3);
						entry.target.textContent = Math.round(target * eased).toLocaleString('zh-CN');
						if (t < 1) requestAnimationFrame(tick);
					}

					requestAnimationFrame(tick);
				});
			}, { threshold: 0.6 });

			document.querySelectorAll('.count-up').forEach((el) => countObserver.observe(el));

			const infraDetail = document.getElementById('infraDetail');
			document.querySelectorAll('.infra-node').forEach((node) => {
				node.addEventListener('click', () => {
					document.querySelectorAll('.infra-node').forEach((item) => item.classList.remove('active'));
					node.classList.add('active');
					if (!infraDetail) return;
					infraDetail.querySelector('h3').textContent = node.dataset.title || '';
					infraDetail.querySelector('strong').textContent = node.dataset.metric || '';
					infraDetail.querySelector('p').textContent = node.dataset.body || '';
					const link = infraDetail.querySelector('a');
					link.href = node.dataset.link || '/investor/';
					link.textContent = node.dataset.linkLabel || '查看证据';
				});
			});

			const assetImage = document.getElementById('assetImage');
			const assetLink = document.getElementById('assetImageLink');
			const assetCaption = document.getElementById('assetCaption');
			document.querySelectorAll('.asset-tabs button').forEach((button) => {
				button.addEventListener('click', () => {
					document.querySelectorAll('.asset-tabs button').forEach((item) => item.classList.remove('active'));
					button.classList.add('active');
					if (assetImage) assetImage.src = button.dataset.src || '';
					if (assetLink) assetLink.href = button.dataset.href || '/investor/';
					if (assetCaption) assetCaption.textContent = button.dataset.caption || '';
				});
			});

			document.querySelectorAll('.mode-switch button').forEach((button) => {
				button.addEventListener('click', () => {
					const mode = button.dataset.mode;
					document.querySelectorAll('.mode-switch button').forEach((item) => item.classList.toggle('active', item === button));
					document.querySelectorAll('.mode-panel').forEach((panel) => {
						panel.classList.toggle('active', panel.dataset.panel === mode);
					});
				});
			});
		</script>

