---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import { readResearchNetwork } from "../../../lib/investor-generated.js";
import { lanePath, stockPath, thesisPath } from "../../../lib/investor-market.js";
import "../../../styles/research-network.css";

const network = readResearchNetwork();
const stats = network.stats || {};
const theses = network.theses || [];
const graph = network.graph || { nodes: [], edges: [] };
const recaps = network.livingRecaps || [];

const nodeGroups = new Map();
for (const node of graph.nodes || []) {
  const group = nodeGroups.get(node.type) || [];
  group.push(node);
  nodeGroups.set(node.type, group);
}
const width = 980;
const height = 600;
const centerX = width / 2;
const centerY = height / 2;
const rings = { thesis: 135, stock: 215, term: 280, event: 340 };
const nodePositions = new Map();
for (const [type, nodes] of nodeGroups.entries()) {
  nodes.forEach((node, index) => {
    const count = Math.max(1, nodes.length);
    const angle = (Math.PI * 2 * index) / count - Math.PI / 2 + (type === "term" ? 0.08 : type === "event" ? 0.16 : 0);
    const ring = rings[type] || 280;
    nodePositions.set(node.id, {
      ...node,
      x: centerX + Math.cos(angle) * ring,
      y: centerY + Math.sin(angle) * ring,
    });
  });
}
const visibleEdges = (graph.edges || []).filter((edge) => nodePositions.has(edge.source) && nodePositions.has(edge.target)).slice(0, 320);
const visibleNodes = [...nodePositions.values()].slice(0, 180);
const formatDate = (value) => String(value || "").replace(/^2026-/, "");
const pct = (value) => `${Math.max(6, Math.min(100, Number(value || 0)))}%`;
const heat = (value) => Math.max(0.14, Math.min(1, Number(value || 0) / 100)).toFixed(2);
const sourceMix = theses
  .flatMap((thesis) => Object.entries(thesis.sourceTypeCounts || {}))
  .reduce((acc, [label, count]) => {
    acc.set(label, (acc.get(label) || 0) + Number(count || 0));
    return acc;
  }, new Map());
const sourceRows = [...sourceMix.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
const maxSource = Math.max(1, ...sourceRows.map((row) => row[1]));
const bucketRows = [...theses
  .reduce((acc, thesis) => {
    const bucket = thesis.practical?.exposureBucket || "主题机会";
    const row = acc.get(bucket) || { bucket, count: 0, score: 0, tone: thesis.practical?.tone || "blue" };
    row.count += 1;
    row.score += Number(thesis.practical?.score || thesis.conviction || 0);
    acc.set(bucket, row);
    return acc;
  }, new Map())
  .values()];
const practicalBuckets = [...bucketRows]
  .map((row) => ({ ...row, avgScore: Math.round(row.score / Math.max(1, row.count)) }))
  .sort((a, b) => b.count - a.count || b.avgScore - a.avgScore)
  .slice(0, 8);
const actionRows = [...theses
  .reduce((acc, thesis) => {
    const label = thesis.practical?.actionLabel || "观察等待";
    acc.set(label, (acc.get(label) || 0) + 1);
    return acc;
  }, new Map())
  .entries()].sort((a, b) => b[1] - a[1]);
const laneRows = [...theses
  .reduce((acc, thesis) => {
    const lane = thesis.lane || thesis.practical?.sectorLane || thesis.practical?.exposureBucket || "未分类赛道";
    const row = acc.get(lane) || { lane, href: thesis.laneHref || lanePath(thesis), count: 0, tickers: new Set(), score: 0 };
    row.count += 1;
    row.score += Number(thesis.practical?.score || thesis.conviction || 0);
    (thesis.stockUniverse || []).slice(0, 6).forEach((stock) => row.tickers.add(stock.ticker));
    acc.set(lane, row);
    return acc;
  }, new Map())
  .values()]
  .map((row) => ({ ...row, tickers: [...row.tickers].slice(0, 8), avgScore: Math.round(row.score / Math.max(1, row.count)) }))
  .sort((a, b) => b.count - a.count || b.avgScore - a.avgScore);
const stockRows = [...theses
  .flatMap((thesis) => (thesis.stockUniverse || []).map((stock) => ({ ...stock, thesisTitle: thesis.title, lane: thesis.lane || thesis.practical?.sectorLane || "" })))
  .reduce((acc, stock) => {
    const row = acc.get(stock.ticker) || { ...stock, count: 0, lanes: new Set() };
    row.count += 1;
    if (stock.lane) row.lanes.add(stock.lane);
    acc.set(stock.ticker, row);
    return acc;
  }, new Map())
  .values()]
  .map((row) => ({ ...row, lanes: [...row.lanes].slice(0, 3) }))
  .sort((a, b) => b.count - a.count || a.ticker.localeCompare(b.ticker));
const thermalLaneRows = [...theses
  .reduce((acc, thesis) => {
    const lane = thesis.lane || thesis.practical?.sectorLane || thesis.practical?.exposureBucket || "未分类赛道";
    const row = acc.get(lane) || {
      lane,
      href: thesis.laneHref || lanePath(thesis),
      count: 0,
      score: 0,
      tickers: new Set(),
      theses: [],
    };
    row.count += 1;
    row.score += Number(thesis.practical?.score || thesis.conviction || 0);
    (thesis.stockUniverse || []).slice(0, 8).forEach((stock) => row.tickers.add(stock.ticker));
    row.theses.push(thesis);
    acc.set(lane, row);
    return acc;
  }, new Map())
  .values()]
  .map((row) => ({
    ...row,
    tickers: [...row.tickers].slice(0, 10),
    avgScore: Math.round(row.score / Math.max(1, row.count)),
    theses: row.theses.sort((a, b) => Number(b.practical?.score || b.conviction || 0) - Number(a.practical?.score || a.conviction || 0)),
  }))
  .sort((a, b) => b.count - a.count || b.avgScore - a.avgScore || a.lane.localeCompare(b.lane));
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
  <head>
    <BaseHead
      title="研究主线网络 · AI Institute 投资研究台"
      description="AI Institute public thesis network with living thesis timelines, evidence graph, and auto-generated recap dashboards."
    />
  </head>
  <body>
    <Header />
    <main class="research-network" data-thesis-count={theses.length}>
      <section class="network-hero">
        <div>
          <div class="network-kicker">AI Institute · Thesis Network</div>
          <h1>研究主线网络</h1>
          <p>{network.summary?.lead || "把研究结果按主线、证据、风险和复盘重新组织，供人类读者快速进入关键问题。"}</p>
          <div class="network-actions">
            <a href="/investor/">返回研究台</a>
            <a href="/investor/timeline/">研究时间线</a>
            <a href="/investor/recaps/">复盘仪表盘</a>
            <a href="/investor/personas/">分析师画像</a>
            <a href="/investor/portfolio/">组合追踪</a>
          </div>
        </div>
        <aside class="network-privacy">
          <span>Public Contract</span>
          <p>{network.summary?.privacyNote}</p>
        </aside>
      </section>

      <section class="network-stat-grid" aria-label="Research network stats">
        <div><span>Theses</span><strong>{stats.thesisCount || theses.length}</strong><em>公开主线</em></div>
        <div><span>Nodes</span><strong>{stats.publicGraphNodes || graph.nodes?.length || 0}</strong><em>Vibe 图谱节点</em></div>
        <div><span>Edges</span><strong>{stats.publicGraphEdges || graph.edges?.length || 0}</strong><em>主线关系</em></div>
        <div><span>Recaps</span><strong>{stats.autoRecaps || recaps.length}</strong><em>自动复盘</em></div>
      </section>

      <section class="network-controls">
        <label for="networkSearch">Search</label>
        <input id="networkSearch" type="search" placeholder="搜索主线、公司、资产、链条、风险..." />
        <a href="/investor-data/research-network.json">JSON 数据</a>
      </section>

      <section class="thermal-section" aria-label="All theses thermal matrix">
        <div class="section-mini-head">
          <span>Thesis Thermal Map</span>
          <strong>{thermalLaneRows.length} lanes · {theses.length} theses</strong>
        </div>
        <div class="thermal-lane-stack">
          {thermalLaneRows.map((row) => (
            <article class="thermal-lane-row" data-search={`${row.lane} ${row.tickers.join(" ")}`}>
              <a class="thermal-lane-head" href={row.href}>
                <span>{row.lane}</span>
                <strong>{row.count} thesis · Score {row.avgScore}</strong>
                <em>{row.tickers.join(" · ") || "待补充标的"}</em>
              </a>
              <div class="thermal-cell-grid">
                {row.theses.map((thesis) => (
                  <a
                    class={`thermal-thesis-cell tone-${thesis.practical?.actionTone || thesis.practical?.tone || "blue"}`}
                    href={thesisPath(thesis)}
                    title={`${thesis.title} · ${thesis.practical?.actionLabel || thesis.directionLabel}`}
                    style={`--heat:${heat(thesis.practical?.score || thesis.conviction)};`}
                    data-search={`${thesis.title} ${thesis.coreView} ${thesis.lane || ""} ${(thesis.stockTickers || []).join(" ")} ${(thesis.topTerms || []).join(" ")} ${thesis.practical?.exposureBucket || ""} ${thesis.practical?.actionLabel || ""}`}
                  >
                    <strong>{thesis.title}</strong>
                    <span>{thesis.practical?.actionLabel || thesis.directionLabel} · {formatDate(thesis.lastSeen)}</span>
                    <em>{(thesis.stockTickers || []).slice(0, 4).join(" · ") || "watch"}</em>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="practical-overview" aria-label="Practical thesis summary">
        <div class="practical-panel">
          <div class="section-mini-head">
            <span>Exposure Buckets</span>
            <strong>可配置主线</strong>
          </div>
          <div class="bucket-stack">
            {practicalBuckets.map((row) => (
              <a href={`?q=${encodeURIComponent(row.bucket)}`} class={`bucket-row tone-${row.tone}`}>
                <span>{row.bucket}</span>
                <strong>{row.count}</strong>
                <em>{row.avgScore}</em>
              </a>
            ))}
          </div>
        </div>
        <div class="practical-panel">
          <div class="section-mini-head">
            <span>Action Map</span>
            <strong>组合动作分布</strong>
          </div>
          <div class="action-stack">
            {actionRows.map(([label, count]) => (
              <button type="button" data-action-filter={label}>
                <span>{label}</span>
                <strong>{count}</strong>
              </button>
            ))}
          </div>
        </div>
        <div class="portfolio-panel" id="portfolio-tracker">
          <div class="section-mini-head">
            <span>Local Portfolio</span>
            <strong>本地 thesis 追踪</strong>
          </div>
          <p>只保存在当前浏览器，用于跟踪主题权重、状态、复核日期和备注。</p>
          <div class="portfolio-toolbar">
            <a href="/investor/portfolio/">打开组合台</a>
            <button type="button" id="exportPortfolio">导出 JSON</button>
            <button type="button" id="clearPortfolio">清空</button>
          </div>
          <div class="portfolio-summary" id="portfolioSummary">尚未添加主线。</div>
          <div class="portfolio-list" id="portfolioList" aria-live="polite"></div>
        </div>
      </section>

      <section class="network-layout">
        <div class="network-stage" aria-label="Public research network graph">
          <div class="graph-toolbar">
            <button type="button" data-graph-filter="all" class="is-active">All</button>
            <button type="button" data-graph-filter="thesis">Thesis</button>
            <button type="button" data-graph-filter="stock">Stocks</button>
            <button type="button" data-graph-filter="term">Terms</button>
            <button type="button" data-graph-filter="event">Events</button>
            <button type="button" id="resetGraph">Reset</button>
          </div>
          <svg id="networkSvg" viewBox={`0 0 ${width} ${height}`} role="img" aria-label="研究主线、关键词和证据事件网络">
            <g id="networkViewport">
              <g class="network-edges">
                {visibleEdges.map((edge) => {
                  const source = nodePositions.get(edge.source);
                  const target = nodePositions.get(edge.target);
                  return <line x1={source.x} y1={source.y} x2={target.x} y2={target.y} class={`edge ${edge.type}`} data-source={edge.source} data-target={edge.target} />;
                })}
              </g>
              <g class="network-center">
                <circle cx={centerX} cy={centerY} r="54"></circle>
                <text x={centerX} y={centerY - 3} text-anchor="middle">AI Institute</text>
                <text x={centerX} y={centerY + 16} text-anchor="middle">ResearchOS</text>
              </g>
              <g class="network-nodes">
                {visibleNodes.map((node) => (
                  <a
                    href={node.href || "#"}
                    class={`node node-${node.type}`}
                    data-node-id={node.id}
                    data-node-type={node.type}
                    data-node-label={node.label}
                    data-node-lane={node.lane || ""}
                    data-node-bucket={node.bucket || ""}
                    data-node-action={node.actionLabel || ""}
                    data-node-score={node.practicalScore || node.conviction || ""}
                    data-search={`${node.label} ${node.type} ${node.lane || ""} ${node.name || ""} ${node.market || ""} ${node.role || ""} ${node.bucket || ""} ${node.actionLabel || ""}`}
                  >
                    <circle cx={node.x} cy={node.y} r={node.type === "thesis" ? 13 : node.type === "stock" ? 10 : node.type === "term" ? 8 : 5}></circle>
                    <text x={node.x} y={node.y - (node.type === "thesis" ? 18 : node.type === "stock" ? 15 : 11)} text-anchor="middle">{node.label}</text>
                  </a>
                ))}
              </g>
            </g>
          </svg>
          <div class="graph-hint">滚轮缩放，拖动画布平移，点击节点查看关系。</div>
        </div>

        <aside class="network-side">
          <section class="selection-panel" id="networkSelection">
            <h2>节点详情</h2>
            <p>点击图谱节点后，这里会显示主线、行动建议和关联关系。</p>
          </section>
          <section>
            <h2>来源构成</h2>
            <div class="source-bars">
              {sourceRows.map(([label, count]) => (
                <div class="source-row">
                  <span>{label}</span>
                  <strong>{count}</strong>
                  <i><b style={`width:${pct((count / maxSource) * 100)}`}></b></i>
                </div>
              ))}
            </div>
          </section>
          <section>
            <h2>最新主线</h2>
            <div class="mini-thesis-list">
              {theses.slice(0, 6).map((thesis) => (
                <a href={thesisPath(thesis)}>
                  <span>{thesis.directionLabel} · {thesis.eventCount} events</span>
                  <strong>{thesis.title}</strong>
                  <em>{formatDate(thesis.lastSeen)}</em>
                </a>
              ))}
            </div>
          </section>
        </aside>
      </section>

      <section class="thesis-section" id="theses">
        <div class="section-headline">
          <span>Living Theses</span>
          <h2>赛道级主线与候选标的</h2>
          <p>每条主线直接落到可观察赛道、候选股票池、组合动作和证据时间线；股票池用于研究跟踪，不等同于买卖建议。</p>
        </div>
        <div class="lane-stock-board">
          <section>
            <div class="section-mini-head">
              <span>Sharp Lanes</span>
              <strong>赛道热度</strong>
            </div>
            <div class="lane-list">
              {laneRows.map((row) => (
                <a href={row.href}>
                  <span>{row.lane}</span>
                  <strong>{row.count} thesis · Score {row.avgScore}</strong>
                  <em>{row.tickers.join(" · ") || "待补充标的"}</em>
                </a>
              ))}
            </div>
          </section>
          <section>
            <div class="section-mini-head">
              <span>Stock Map</span>
              <strong>高频候选标的</strong>
            </div>
            <div class="stock-cloud">
              {stockRows.map((stock) => (
                <a href={stock.href || stockPath(stock)}>
                  <strong>{stock.ticker}</strong>
                  <span>{stock.name}</span>
                  <em>{stock.count} thesis · {stock.market}</em>
                </a>
              ))}
            </div>
          </section>
        </div>
        <div class="thesis-grid">
          {theses.map((thesis) => (
            <article
              class="thesis-card"
              id={thesis.id}
              data-thesis-id={thesis.id}
              data-title={thesis.title}
              data-bucket={thesis.practical?.exposureBucket || "主题机会"}
              data-action={thesis.practical?.actionLabel || "观察等待"}
              data-score={thesis.practical?.score || thesis.conviction || 0}
              data-risk-budget={thesis.practical?.riskBudget || ""}
              data-search={`${thesis.title} ${thesis.coreView} ${thesis.lane || ""} ${(thesis.stockTickers || []).join(" ")} ${(thesis.stockUniverse || []).map((stock) => stock.name).join(" ")} ${(thesis.topTerms || []).join(" ")} ${thesis.practical?.exposureBucket || ""} ${thesis.practical?.actionLabel || ""}`}
            >
              <div class="thesis-top">
                <span>{thesis.lane || thesis.practical?.sectorLane || thesis.directionLabel}</span>
                <span>{formatDate(thesis.firstSeen)} → {formatDate(thesis.lastSeen)}</span>
              </div>
              <h3><a href={thesisPath(thesis)}>{thesis.title}</a></h3>
              <p>{thesis.coreView}</p>
              <div class={`practical-callout tone-${thesis.practical?.actionTone || thesis.practical?.tone || "blue"}`}>
                <div>
                  <span>{thesis.practical?.exposureBucket || "主题机会"} · {thesis.directionLabel}</span>
                  <strong>{thesis.practical?.actionLabel || "观察等待"}</strong>
                </div>
                <button
                  type="button"
                  class="track-thesis"
                  data-track-id={thesis.id}
                  data-track-title={thesis.title}
                  data-track-bucket={thesis.practical?.exposureBucket || "主题机会"}
                  data-track-action={thesis.practical?.actionLabel || "观察等待"}
                  data-track-score={thesis.practical?.score || thesis.conviction || 0}
                  data-track-risk={thesis.practical?.riskBudget || ""}
                >
                  追踪
                </button>
              </div>
              <div class="stock-chip-row">
                {(thesis.stockUniverse || thesis.practical?.primaryStocks || []).slice(0, 8).map((stock) => (
                  <a href={stock.href || stockPath(stock)} title={`${stock.name} · ${stock.role || ""}`}>
                    <strong>{stock.ticker}</strong>
                    <span>{stock.market}</span>
                  </a>
                ))}
              </div>
              <div class="practical-copy">
                <p>{thesis.practical?.portfolioUse}</p>
                <span>{thesis.practical?.portfolioRole || thesis.practical?.actionLabel || "观察"}</span>
                <span>{thesis.practical?.weightGuide || thesis.practical?.riskBudget}</span>
                <span>{thesis.practical?.timeHorizon || thesis.practical?.reviewCadence}</span>
                <span>{thesis.practical?.deepResearchPriority || "常规跟踪"}</span>
                <span>{thesis.practical?.reviewCadence}</span>
              </div>
              <div class="thesis-meter" aria-label="Conviction">
                <i style={`width:${pct(thesis.conviction)}`}></i>
                <strong>{thesis.conviction}</strong>
              </div>
              <div class="thesis-counters">
                <span>支持 {thesis.supports}</span>
                <span>风险 {thesis.risks}</span>
                <span>观察 {thesis.neutral}</span>
                <span>分析师 {thesis.analystCount}</span>
              </div>
              <div class="term-row">
                {(thesis.topTerms || []).slice(0, 8).map((term) => <a href={`?q=${encodeURIComponent(term)}`}>{term}</a>)}
              </div>
              <div class="timeline-strip">
                {(thesis.timeline || []).slice(-14).map((point) => (
                  <span title={`${point.date}: 支持 ${point.supports} / 风险 ${point.risks}`} style={`height:${Math.max(12, Math.min(52, Number(point.value || 20)))}px`} class={point.risks > point.supports ? "risk" : point.supports ? "support" : "neutral"}></span>
                ))}
              </div>
              <div class="event-stack">
                {(thesis.events || []).slice(0, 3).map((event) => (
                  <a href={event.href || thesisPath(thesis)}>
                    <span>{formatDate(event.date)} · {event.sourceLabel} · {event.supportLabel}</span>
                    <strong>{event.title}</strong>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="recap-section" id="living-recaps">
        <div class="section-headline">
          <span>Auto Recaps</span>
          <h2>自动更新复盘</h2>
          <p>由主线时间线生成，和手工关键复盘合并发布。点击可进入现有复盘仪表盘模板。</p>
        </div>
        <div class="recap-grid">
          {recaps.slice(0, 16).map((recap) => (
            <article class="recap-card" data-search={`${recap.title} ${recap.subtitle}`}>
              <div class="thesis-top">
                <span>{recap.badge}</span>
                <span>{recap.date}</span>
              </div>
              <h3><a href={`/investor/recaps/${recap.slug}/`}>{recap.title}</a></h3>
              <p>{recap.subtitle}</p>
              <div class="recap-metrics">
                {(recap.metrics || []).slice(0, 4).map((metric) => (
                  <span class={`accent-${metric.accent || "blue"}`}><strong>{metric.value}</strong>{metric.label}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <script>
      const input = document.getElementById("networkSearch");
      const searchable = [...document.querySelectorAll("[data-search]")];
      const actionButtons = [...document.querySelectorAll("[data-action-filter]")];
      const graphButtons = [...document.querySelectorAll("[data-graph-filter]")];
      const nodes = [...document.querySelectorAll(".node[data-node-id]")];
      const edges = [...document.querySelectorAll(".edge[data-source][data-target]")];
      const selection = document.getElementById("networkSelection");
      const svg = document.getElementById("networkSvg");
      const viewport = document.getElementById("networkViewport");
      const portfolioKey = "vibe.researchNetwork.portfolio.v1";
      let graphFilter = "all";
      let actionFilter = "";
      let panX = 0;
      let panY = 0;
      let zoom = 1;
      let dragging = false;
      let lastPoint = null;

      function readPortfolio() {
        try {
          return JSON.parse(localStorage.getItem(portfolioKey) || "[]");
        } catch {
          return [];
        }
      }

      function writePortfolio(items) {
        localStorage.setItem(portfolioKey, JSON.stringify(items));
        renderPortfolio();
      }

      function upsertPortfolio(item) {
        const items = readPortfolio();
        const index = items.findIndex((entry) => entry.id === item.id);
        const next = {
          ...item,
          status: item.status || "观察",
          weight: item.weight || "0",
          reviewDate: item.reviewDate || "",
          note: item.note || "",
          updatedAt: new Date().toISOString(),
        };
        if (index >= 0) items[index] = { ...items[index], ...next };
        else items.unshift(next);
        writePortfolio(items);
      }

      function renderPortfolio() {
        const items = readPortfolio();
        const list = document.getElementById("portfolioList");
        const summary = document.getElementById("portfolioSummary");
        if (!list || !summary) return;
        const totalWeight = items.reduce((sum, item) => sum + Number(item.weight || 0), 0);
        summary.textContent = items.length
          ? `${items.length} 条主线 · 目标权重 ${totalWeight.toFixed(1)}% · 本地浏览器保存`
          : "尚未添加主线。";
        list.innerHTML = items
          .map((item) => `
            <article class="portfolio-item" data-id="${item.id}">
              <div>
                <span>${item.bucket || "主题机会"} · ${item.action || "观察等待"} · ${item.score || ""}</span>
                <strong><a href="#${item.id}">${item.title}</a></strong>
                <em>${item.risk || ""}</em>
              </div>
              <label>状态
                <select data-field="status">
                  ${["观察", "验证仓", "核心仓", "对冲", "退出"].map((status) => `<option ${status === item.status ? "selected" : ""}>${status}</option>`).join("")}
                </select>
              </label>
              <label>权重
                <input data-field="weight" type="number" min="0" max="100" step="0.5" value="${item.weight || "0"}" />
              </label>
              <label>复核
                <input data-field="reviewDate" type="date" value="${item.reviewDate || ""}" />
              </label>
              <label>备注
                <input data-field="note" type="text" value="${String(item.note || "").replaceAll('"', "&quot;")}" />
              </label>
              <button type="button" data-remove="${item.id}">移除</button>
            </article>
          `)
          .join("");
      }

      function syncSearch() {
        const query = String(input?.value || new URLSearchParams(location.search).get("q") || "").toLowerCase().trim();
        if (input && !input.value && query) input.value = query;
        searchable.forEach((item) => {
          const text = String(item.dataset.search || "").toLowerCase();
          const action = String(item.dataset.action || "");
          const type = String(item.dataset.nodeType || "");
          const matchQuery = !query || text.includes(query);
          const matchAction = !actionFilter || action === actionFilter || !item.classList.contains("thesis-card");
          const matchGraph = graphFilter === "all" || !item.classList.contains("node") || type === graphFilter;
          const match = matchQuery && matchAction && matchGraph;
          item.classList.toggle("is-muted", !match);
          item.classList.toggle("is-hidden", !match && item.classList.contains("thesis-card"));
        });
      }

      function resetGraphFocus() {
        nodes.forEach((node) => node.classList.remove("is-selected", "is-related"));
        edges.forEach((edge) => edge.classList.remove("is-selected", "is-related"));
        if (selection) {
          selection.innerHTML = "<h2>节点详情</h2><p>点击图谱节点后，这里会显示主线、行动建议和关联关系。</p>";
        }
      }

      function selectNode(node) {
        const id = node.dataset.nodeId;
        const relatedIds = new Set([id]);
        nodes.forEach((item) => item.classList.toggle("is-selected", item === node));
        edges.forEach((edge) => {
          const related = edge.dataset.source === id || edge.dataset.target === id;
          edge.classList.toggle("is-related", related);
          edge.classList.toggle("is-selected", related);
          if (related) {
            relatedIds.add(edge.dataset.source);
            relatedIds.add(edge.dataset.target);
          }
        });
        nodes.forEach((item) => item.classList.toggle("is-related", relatedIds.has(item.dataset.nodeId)));
        if (selection) {
          const href = node.getAttribute("href") || "#";
          const isThesis = node.dataset.nodeType === "thesis";
          selection.innerHTML = `
            <h2>${node.dataset.nodeLabel || "节点"}</h2>
            <div class="selection-tags">
              <span>${node.dataset.nodeType || "node"}</span>
              ${node.dataset.nodeLane ? `<span>${node.dataset.nodeLane}</span>` : ""}
              ${node.dataset.nodeBucket ? `<span>${node.dataset.nodeBucket}</span>` : ""}
              ${node.dataset.nodeAction ? `<span>${node.dataset.nodeAction}</span>` : ""}
              ${node.dataset.nodeScore ? `<span>Score ${node.dataset.nodeScore}</span>` : ""}
            </div>
            <p>${isThesis ? "这是一条可加入组合追踪的研究主线。关联线显示它的关键词和最新证据。" : "点击关联主线可以进入具体 thesis，或使用搜索收窄关系。"}</p>
            <div class="network-actions compact-actions">
              <a href="${href}">打开节点</a>
              ${isThesis ? `<button type="button" data-select-track="${id}">加入追踪</button>` : ""}
            </div>
          `;
        }
      }

      function setTransform() {
        if (viewport) viewport.setAttribute("transform", `translate(${panX} ${panY}) scale(${zoom})`);
      }

      function svgPoint(event) {
        const rect = svg.getBoundingClientRect();
        return { x: event.clientX - rect.left, y: event.clientY - rect.top };
      }

      input?.addEventListener("input", syncSearch);
      actionButtons.forEach((button) => {
        button.addEventListener("click", () => {
          actionFilter = actionFilter === button.dataset.actionFilter ? "" : button.dataset.actionFilter;
          actionButtons.forEach((item) => item.classList.toggle("is-active", item === button && Boolean(actionFilter)));
          syncSearch();
        });
      });
      graphButtons.forEach((button) => {
        button.addEventListener("click", () => {
          graphFilter = button.dataset.graphFilter || "all";
          graphButtons.forEach((item) => item.classList.toggle("is-active", item === button));
          resetGraphFocus();
          syncSearch();
        });
      });
      nodes.forEach((node) => {
        node.addEventListener("click", (event) => {
          event.preventDefault();
          selectNode(node);
        });
      });
      svg?.addEventListener("wheel", (event) => {
        event.preventDefault();
        const direction = event.deltaY > 0 ? -0.08 : 0.08;
        zoom = Math.max(0.65, Math.min(2.2, zoom + direction));
        setTransform();
      }, { passive: false });
      svg?.addEventListener("pointerdown", (event) => {
        if (event.target.closest?.(".node")) return;
        dragging = true;
        lastPoint = svgPoint(event);
        svg.setPointerCapture?.(event.pointerId);
      });
      svg?.addEventListener("pointermove", (event) => {
        if (!dragging || !lastPoint) return;
        const point = svgPoint(event);
        panX += (point.x - lastPoint.x) / zoom;
        panY += (point.y - lastPoint.y) / zoom;
        lastPoint = point;
        setTransform();
      });
      svg?.addEventListener("pointerup", () => {
        dragging = false;
        lastPoint = null;
      });
      document.getElementById("resetGraph")?.addEventListener("click", () => {
        panX = 0;
        panY = 0;
        zoom = 1;
        setTransform();
        resetGraphFocus();
      });
      document.addEventListener("click", (event) => {
        const track = event.target.closest?.(".track-thesis");
        const selectTrack = event.target.closest?.("[data-select-track]");
        if (track) {
          upsertPortfolio({
            id: track.dataset.trackId,
            title: track.dataset.trackTitle,
            bucket: track.dataset.trackBucket,
            action: track.dataset.trackAction,
            score: track.dataset.trackScore,
            risk: track.dataset.trackRisk,
          });
        }
        if (selectTrack) {
          const card = document.querySelector(`[data-thesis-id="${selectTrack.dataset.selectTrack}"]`);
          if (card) {
            upsertPortfolio({
              id: card.dataset.thesisId,
              title: card.dataset.title,
              bucket: card.dataset.bucket,
              action: card.dataset.action,
              score: card.dataset.score,
              risk: card.dataset.riskBudget,
            });
          }
        }
        const remove = event.target.closest?.("[data-remove]");
        if (remove) writePortfolio(readPortfolio().filter((item) => item.id !== remove.dataset.remove));
      });
      document.addEventListener("change", (event) => {
        const field = event.target.closest?.("[data-field]");
        const itemEl = event.target.closest?.(".portfolio-item");
        if (!field || !itemEl) return;
        const items = readPortfolio();
        const item = items.find((entry) => entry.id === itemEl.dataset.id);
        if (!item) return;
        item[field.dataset.field] = field.value;
        localStorage.setItem(portfolioKey, JSON.stringify(items));
        renderPortfolio();
      });
      document.getElementById("exportPortfolio")?.addEventListener("click", () => {
        const blob = new Blob([JSON.stringify(readPortfolio(), null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `vibe-thesis-portfolio-${new Date().toISOString().slice(0, 10)}.json`;
        link.click();
        URL.revokeObjectURL(url);
      });
      document.getElementById("clearPortfolio")?.addEventListener("click", () => {
        if (confirm("清空本地 thesis 追踪列表？")) writePortfolio([]);
      });
      syncSearch();
      renderPortfolio();
    </script>
  </body>
</html>
