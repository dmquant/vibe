---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import {
  readAnalystPersonaTimelines,
  readChangeRadar,
  readDailyDashboard,
  readDeepIndex,
  readOddsBoard,
  readRecapDashboards,
  readResearchNetwork,
  readSiteData,
} from "../../lib/investor-generated.js";
import { buildOddsIndexes, lanePath, oddsLine, probabilityLabel, stockPath, thesisPath } from "../../lib/investor-market.js";
import { buildWeeklyPanoramaBundle } from "../../lib/weekly-panorama.js";
import "../../styles/investment-portal.css";

const siteData = readSiteData();
const daily = readDailyDashboard();
const radar = readChangeRadar();
const network = readResearchNetwork();
const recapData = readRecapDashboards();
const deepData = readDeepIndex();
const personaData = readAnalystPersonaTimelines();
const odds = readOddsBoard();
const oddsIndexes = buildOddsIndexes(odds);
const laneOddsByHref = new Map((odds.laneLines || []).map((item) => [item.href, item]));
const panorama = buildWeeklyPanoramaBundle();

const stats = siteData.stats || {};
const theses = network.theses || [];
const readerReports = (Array.isArray(siteData.readerReports) ? siteData.readerReports : [])
  .sort((a, b) => String(b.date || "").localeCompare(String(a.date || "")));
const readerLead = daily.readerReport || readerReports[0] || null;
const priorityViews = readerLead?.priorityViews || [];
const recentTheses = [...theses]
  .sort((a, b) => String(b.lastSeen || "").localeCompare(String(a.lastSeen || "")) || Number(b.practical?.score || b.conviction || 0) - Number(a.practical?.score || a.conviction || 0))
  .slice(0, 8);

const laneRows = [...theses
  .reduce((acc, thesis) => {
    const lane = thesis.lane || thesis.practical?.sectorLane || "未分类赛道";
    const row = acc.get(lane) || {
      lane,
      href: thesis.laneHref || lanePath(thesis),
      theses: 0,
      score: 0,
      lastSeen: "",
      stocks: new Map(),
    };
    row.theses += 1;
    row.score += Number(thesis.practical?.score || thesis.conviction || 0);
    row.lastSeen = [row.lastSeen, thesis.lastSeen || ""].sort().pop();
    for (const stock of (thesis.stockUniverse || []).slice(0, 8)) row.stocks.set(stock.ticker, stock);
    acc.set(lane, row);
    return acc;
  }, new Map())
  .values()]
  .map((row) => ({ ...row, avgScore: Math.round(row.score / Math.max(1, row.theses)), stocks: [...row.stocks.values()] }))
  .sort((a, b) => String(b.lastSeen).localeCompare(String(a.lastSeen)) || b.avgScore - a.avgScore)
  .slice(0, 8);

const stockRows = [...theses
  .flatMap((thesis) => (thesis.stockUniverse || []).map((stock) => ({ ...stock, thesis })))
  .reduce((acc, item) => {
    const current = acc.get(item.ticker) || { ...item, theses: new Set(), lanes: new Set(), score: 0 };
    current.theses.add(item.thesis.id);
    current.lanes.add(item.thesis.lane || item.thesis.practical?.sectorLane || "主题机会");
    current.score += Number(item.thesis.practical?.score || item.thesis.conviction || 0);
    acc.set(item.ticker, current);
    return acc;
  }, new Map())
  .values()]
  .map((row) => ({ ...row, thesisCount: row.theses.size, laneCount: row.lanes.size, lanes: [...row.lanes] }))
  .sort((a, b) => b.thesisCount - a.thesisCount || b.score - a.score)
  .slice(0, 12);
const signalRows = [
  ...(radar.riskAlerts || []).map((item) => ({ ...item, type: "RISK", detail: item.summary, date: radar.date })),
  ...(radar.mustRead || []).map((item) => ({ ...item, type: "READ", detail: item.reason, date: radar.date })),
].filter((item, index, rows) => rows.findIndex((candidate) => candidate.href === item.href) === index).slice(0, 8);

const weeklyCalls = (panorama.recommendations?.calls || []).slice(0, 6);
const latestRecaps = [...(recapData.dashboards || [])]
  .sort((a, b) => String(b.date || "").localeCompare(String(a.date || "")))
  .slice(0, 6);
const deepResearch = (deepData.items || []).slice(0, 6);
const personas = [...(personaData.personas || [])]
  .sort((a, b) => String(b.lastSeen || "").localeCompare(String(a.lastSeen || "")) || Number(b.eventCount || 0) - Number(a.eventCount || 0))
  .slice(0, 6);
const actionTone = (action) => String(action || "HOLD").toLowerCase();
const searchText = (...values) => values.flat(Infinity).filter(Boolean).join(" ").replaceAll('"', "&quot;");
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
  <head>
    <BaseHead
      title="投资研究门户 · AI Institute"
      description="AI Institute reader-first investment portal covering daily briefs, weekly panorama, theses, lanes, stocks, portfolios, recaps, and deep research."
    />
  </head>
  <body>
    <Header />
    <main class="investment-portal">
      <section class="portal-hero">
        <div class="portal-hero-copy">
          <div class="portal-kicker">AI Institute / Investment Portal</div>
          <h1>投资研究决策台</h1>
          <p>{daily.readerReport?.summary || daily.summary?.lead || "把每日研究结果重组为可读判断、可追踪主线、可点击赛道与标的，以及可复核的组合动作。"}</p>
          <div class="portal-actions">
            <a class="primary" href={readerLead?.href || "/investor/daily/"}>读今日综合</a>
            <a href="/investor/signals/">看变化信号</a>
            <a href="/investor/panorama/">看本周结论</a>
            <a href="/investor/portfolio/">打开组合台</a>
          </div>
        </div>
        <aside class="portal-pulse" aria-label="Research system pulse">
          <div class="pulse-head"><span>System pulse</span><i></i></div>
          <strong>{daily.date || stats.daily_dashboard_date || "Latest"}</strong>
          <p>{daily.summary?.headline || "最新研究合约已同步"}</p>
          <div class="pulse-grid">
            <span><b>{network.stats?.thesisCount || 0}</b> theses</span>
            <span><b>{network.stats?.laneCount || 0}</b> lanes</span>
            <span><b>{network.stats?.stockCount || 0}</b> stocks</span>
            <span><b>{readerReports.length}</b> reader memos</span>
          </div>
        </aside>
      </section>

      <section class="portal-commandbar" aria-label="Portal search and modes">
        <label for="portalSearch">Search the investment map</label>
        <input id="portalSearch" type="search" placeholder="搜索 thesis、赛道、ticker、复盘或分析师..." />
        <a href="/investor/start/">使用说明</a>
        <a href="/investor/research-network/">完整网络</a>
      </section>

      <section class="portal-stat-strip" aria-label="Published research counts">
        <a href="/investor/daily/"><span>Today</span><strong>{daily.date || "latest"}</strong><em>晨会与读者综合</em></a>
        <a href="/investor/signals/"><span>Signals</span><strong>{radar.stats?.newEvidence || 0}</strong><em>新增证据</em></a>
        <a href="/investor/theses/"><span>Theses</span><strong>{network.stats?.thesisCount || 0}</strong><em>可证伪主线</em></a>
        <a href="/investor/lanes/"><span>Lanes</span><strong>{network.stats?.laneCount || 0}</strong><em>可投资赛道</em></a>
        <a href="/investor/stocks/"><span>Stocks</span><strong>{network.stats?.stockCount || 0}</strong><em>研究暴露节点</em></a>
        <a href="/investor/panorama/"><span>Weekly</span><strong>{panorama.week}</strong><em>操作全景</em></a>
        <a href="/investor/portfolio/"><span>Portfolio</span><strong>LOCAL</strong><em>本地组合工作台</em></a>
      </section>

      <section class="portal-band portal-decision-band">
        <div class="portal-section-head">
          <div><span>Decision Desk</span><h2>今天读什么，本周做什么</h2></div>
          <p>晨会负责压缩变化，周度全景把变化映射到操作、仓位含义与证伪条件。</p>
        </div>
        <div class="decision-layout">
          <article class="daily-decision">
            <div class="panel-label"><span>Today / 今日</span><a href="/investor/daily/">完整看板</a></div>
            <h3>{daily.summary?.headline || "晨会信号已同步"}</h3>
            <p>{daily.summary?.lead}</p>
            <div class="daily-metrics">
              <span><strong>{daily.stats?.sections || 0}</strong>板块</span>
              <span><strong>{daily.stats?.marketQuotes || 0}</strong>报价</span>
              <span><strong>{daily.stats?.deepResearch || 0}</strong>深研</span>
              <span><strong>{daily.stats?.handoffs || 0}</strong>传递</span>
            </div>
            <div class="brief-list">
              {(daily.morningSections || []).slice(0, 4).map((item) => (
                <a class="portal-searchable" data-search={searchText(item.title, item.detail)} href={item.href || "/investor/daily/"}>
                  <span>{item.label}</span><strong>{item.title}</strong><em>{item.detail}</em>
                </a>
              ))}
            </div>
          </article>

          <div class="weekly-call-list">
            <div class="panel-label"><span>Weekly / 本周操作结论</span><a href="/investor/panorama/">完整全景</a></div>
            {weeklyCalls.map((call) => (
              <a class={`weekly-call action-${actionTone(call.action)} portal-searchable`} data-search={searchText(call.action, call.target, call.lane, call.driver, call.linkedTicker)} href={call.href}>
                <span>{call.action}</span>
                <div><strong>{call.target}</strong><p>{call.driver}</p></div>
                <em>{call.evidenceDate}</em>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="portal-band" id="research-map">
        <div class="portal-section-head">
          <div><span>Market Registry</span><h2>主线、赛道、股票、信号各有自己的入口</h2></div>
          <p>首页只显示近期切片；完整注册表提供搜索、过滤与排序，网络页保留给关系探索。</p>
        </div>
        <div class="research-map-grid">
          <section class="map-column thesis-column">
            <header><span>01</span><div><strong>Theses</strong><em>{network.stats?.thesisCount || theses.length} 条主线</em></div><a href="/investor/theses/">全部</a></header>
            <div>
              {recentTheses.map((thesis) => (
                <a class="map-row portal-searchable" data-search={searchText(thesis.title, thesis.lane, thesis.stockTickers)} href={thesisPath(thesis)}>
                  <span>{thesis.practical?.actionLabel || thesis.directionLabel}</span>
                  <strong>{thesis.title}</strong>
                  <em>{thesis.lastSeen} · 20D house {probabilityLabel(oddsLine(oddsIndexes.theses.get(thesis.id), "20d")?.pHouse)} · score {thesis.practical?.score || thesis.conviction}</em>
                </a>
              ))}
            </div>
          </section>

          <section class="map-column lane-column">
            <header><span>02</span><div><strong>Lanes / 赛道</strong><em>{network.stats?.laneCount || laneRows.length} 条赛道</em></div><a href="/investor/lanes/">全部</a></header>
            <div>
              {laneRows.map((lane) => (
                <a class="map-row portal-searchable" data-search={searchText(lane.lane, lane.stocks.map((stock) => stock.ticker))} href={lane.href}>
                  <span>{lane.theses} theses · 20D {probabilityLabel(oddsLine(laneOddsByHref.get(lane.href), "20d")?.pHouse)}</span>
                  <strong>{lane.lane}</strong>
                  <em>{lane.stocks.slice(0, 5).map((stock) => stock.ticker).join(" · ")}</em>
                </a>
              ))}
            </div>
          </section>

          <section class="map-column stock-column">
            <header><span>03</span><div><strong>Stocks / 标的</strong><em>{network.stats?.stockCount || stockRows.length} 个节点</em></div><a href="/investor/stocks/">全部</a></header>
            <div class="stock-node-grid">
              {stockRows.map((stock) => (
                <a class="stock-node portal-searchable" data-search={searchText(stock.ticker, stock.name, stock.role, stock.lanes)} href={stock.href || stockPath(stock)}>
                  <span>{stock.market}</span><strong>{stock.ticker}</strong><em>{stock.name}</em><small>{stock.thesisCount} theses · 20D linked {probabilityLabel(oddsLine(oddsIndexes.stocks.get(stock.ticker), "20d")?.pHouse)}</small>
                </a>
              ))}
            </div>
          </section>

          <section class="map-column signal-column">
            <header><span>04</span><div><strong>Signals / 信号</strong><em>{radar.stats?.newEvidence || 0} 条新增证据</em></div><a href="/investor/signals/">全部</a></header>
            <div>
              {signalRows.map((signal) => (
                <a class="map-row portal-searchable" data-search={searchText(signal.type, signal.title, signal.detail, signal.chain)} href={signal.href}>
                  <span>{signal.type} · {signal.chain || radar.date}</span>
                  <strong>{signal.title}</strong>
                  <em>{signal.detail}</em>
                </a>
              ))}
            </div>
          </section>
        </div>
      </section>

      <section class="portal-band reader-band" id="reader">
        <div class="portal-section-head">
          <div><span>Reader Layer</span><h2>人类友好的研究结果</h2></div>
          <p>先给一句话结论、关键变化与证伪条件，再把证据和来源放回可追溯的研究网络。</p>
        </div>
        <div class="reader-layout">
          <article class="reader-lead">
            <div class="panel-label"><span>Latest Reader Memo</span><a href="/investor/archive/">全部报告</a></div>
            {readerLead ? (
              <>
                <span class="reader-date">{readerLead.date}</span>
                <h3><a href={readerLead.href}>{readerLead.title}</a></h3>
                <p>{readerLead.summary}</p>
                <div class="priority-grid">
                  {priorityViews.slice(0, 3).map((view, index) => (
                    <a class="portal-searchable" data-search={searchText(view.title, view.view, view.whyItMatters)} href={readerLead.href}>
                      <span>{String(index + 1).padStart(2, "0")}</span><strong>{view.title}</strong><em>{view.view}</em>
                    </a>
                  ))}
                </div>
              </>
            ) : <p>读者报告将在本次更新后发布。</p>}
          </article>
          <aside class="reader-archive">
            <div class="panel-label"><span>Recent Memos</span><a href="/investor/archive/">档案地图</a></div>
            {readerReports.slice(0, 7).map((report) => (
              <a class="portal-searchable" data-search={searchText(report.title, report.summary, report.date)} href={report.href}>
                <span>{report.date}</span><strong>{report.title}</strong><em>{report.summary}</em>
              </a>
            ))}
          </aside>
        </div>
      </section>

      <section class="portal-band" id="deep">
        <div class="portal-section-head">
          <div><span>Research Memory</span><h2>深度研究、动态复盘与分析师视角</h2></div>
          <p>深研回答机制和情景，复盘回答观点如何变化，persona 回答不同研究视角如何参与同一主线。</p>
        </div>
        <div class="memory-grid">
          <section>
            <header><strong>Deep Research</strong><a href="/investor/console/#deep">完整目录</a></header>
            {deepResearch.map((item) => (
              <a class="memory-row portal-searchable" data-search={searchText(item.title_zh, item.title_en, item.summary_zh, item.chains)} href={item.href}>
                <span>{item.date} · {item.evidence_count} evidence</span><strong>{item.title_zh}</strong><em>{item.summary_zh}</em>
              </a>
            ))}
          </section>
          <section>
            <header><strong>Living Recaps</strong><a href="/investor/recaps/">全部复盘</a></header>
            {latestRecaps.map((recap) => (
              <a class="memory-row portal-searchable" data-search={searchText(recap.title, recap.subtitle, recap.badge)} href={`/investor/recaps/${recap.slug}/`}>
                <span>{recap.date} · {recap.badge}</span><strong>{recap.title}</strong><em>{recap.subtitle}</em>
              </a>
            ))}
          </section>
          <section>
            <header><strong>Analyst Personas</strong><a href="/investor/personas/">全部画像</a></header>
            {personas.map((persona) => (
              <a class="memory-row portal-searchable" data-search={searchText(persona.name, persona.nameEn, persona.currentView, persona.topTerms)} href={persona.href || `/investor/personas/#${persona.id}`}>
                <span>{persona.lastSeen} · {persona.thesisCount} theses</span><strong>{persona.name}</strong><em>{persona.currentView}</em>
              </a>
            ))}
          </section>
        </div>
      </section>

      <section class="portal-band portal-access-band">
        <div class="portal-section-head">
          <div><span>Access Map</span><h2>按任务选择入口</h2></div>
          <p>门户负责决策顺序；高级控制台、知识图谱和报告库保留给需要继续检索与验证的读者。</p>
        </div>
        <div class="access-grid">
          <a href="/investor/signals/"><span>01</span><strong>变化信号</strong><em>今天什么需要重判</em></a>
          <a href="/investor/theses/"><span>02</span><strong>投资主线</strong><em>当前判断与证伪条件</em></a>
          <a href="/investor/lanes/"><span>03</span><strong>可投资赛道</strong><em>产业机制如何传导</em></a>
          <a href="/investor/stocks/"><span>04</span><strong>股票节点</strong><em>公司暴露在哪些主线</em></a>
          <a href="/investor/daily/"><span>05</span><strong>晨会看板</strong><em>今日证据与读者综合</em></a>
          <a href="/investor/panorama/"><span>06</span><strong>周度全景</strong><em>本周如何定位</em></a>
          <a href="/investor/portfolio/"><span>07</span><strong>组合追踪</strong><em>如何纳入风险预算</em></a>
          <a href="/investor/research-network/"><span>08</span><strong>完整网络</strong><em>论点和证据如何连接</em></a>
        </div>
      </section>
    </main>

    <script>
      const searchInput = document.getElementById("portalSearch");
      const searchable = [...document.querySelectorAll(".portal-searchable")];
      searchInput?.addEventListener("input", () => {
        const query = String(searchInput.value || "").toLowerCase().trim();
        searchable.forEach((item) => {
          item.classList.toggle("is-filtered", Boolean(query) && !String(item.dataset.search || "").toLowerCase().includes(query));
        });
      });

    </script>
  </body>
</html>
