  ["D09", "锂价跌破 10 万", "05-04", "现货仍在 17.7 万元/吨附近，后续又反向打脸。"],
  ["D12", "红利无限承接", "06-30", "承接上限与拥挤分位约束同时出现。"],
];

const disputes = [
  "红利拥挤：物理红利超配 vs 拥挤出清换仓，07-01 行动站在出清侧。",
  "油价假性宽松：央行超调 vs 库存紧与核心 CPI 传导，尚未裁决。",
  "杠铃低配 TMT：政策工具误读 vs 类滞胀杠铃，科技权重仍有争议。",
  "银行：NIM 筑底与 H 股股息 vs 美元计总回报价值陷阱。",
  "生猪：Q4 周期底部反弹 vs 饲料降本诱发二次育肥。",
  "AI SaaS：毛利修复条件未被 ARR/续费率证据确认。",
  "FCF 拐点：利润表拐点同季确认 vs 租赁义务和自由现金流压力。",
  "指数口径与 SPCX 锚点：多次数据口径冲突要求先 QA 后加杠杆。",
  "国家队承接归因：成交量推断不能替代中登/申赎验证。",
];

const statusCounts = [...thesisNodes.reduce((acc, item) => {
  acc.set(item.status, (acc.get(item.status) || 0) + 1);
  return acc;
}, new Map()).entries()];
const maxLaneStocks = Math.max(...lanes.map((lane) => lane.stocks.length));
const network = readResearchNetwork();
const publicStockTickers = new Set((network.theses || []).flatMap((thesis) => (thesis.stockUniverse || []).map((stock) => stock.ticker)));
const serializedLanes = JSON.stringify(lanes).replaceAll("<", "\\u003c");
const serializedTheses = JSON.stringify(thesisNodes).replaceAll("<", "\\u003c");
const serializedPublicStocks = JSON.stringify([...publicStockTickers]).replaceAll("<", "\\u003c");

const stockHref = (ticker) => publicStockTickers.has(ticker) ? stockPath(ticker) : `/investor/research-network/?q=${encodeURIComponent(ticker)}`;
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
  <head>
    <BaseHead
      title="Fable 0702 全量研究复盘 · AI Institute"
      description="把 2026-07-02 Fable review 转化为可交互的论点、车道、知识覆盖与组合对齐度可视化。"
    />
  </head>
  <body>
    <Header />
    <main class="fable-review" data-report-date={reportDate}>
      <section class="fable-hero">
        <div>
          <div class="fable-kicker">Fable Review · {reportDate}</div>
          <h1>研究成果全量挖掘复盘</h1>
          <p>
            把 228 篇研究合成报告、17,333 条预测流、26 本组合账本与产业链知识覆盖重新压缩成一个可读、可点击、可执行的研究驾驶舱。
          </p>
          <div class="fable-actions">
            <a href="/investor/">返回研究台</a>
            <a href="/investor/research-network/">研究网络</a>
            <a href="/investor/portfolio/">组合追踪</a>
            <a href="/investor/recaps/">复盘仪表盘</a>
          </div>
        </div>
        <aside class="fable-verdict">
          <span>Prime Finding</span>
          <strong>研究引擎和下注引擎是两台不同步的机器。</strong>
          <p>最新战术判断 T03 在组合中零表达，而需要切出的科技动量仍是 A 股侧最大共识仓之一。</p>
        </aside>
      </section>

      <section class="fable-stat-grid" aria-label="Corpus summary">
        {corpusStats.map((item) => (
          <article>
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <em>{item.note}</em>
          </article>
        ))}
      </section>

      <section class="fable-layout">
        <article class="fable-panel fable-map-panel">
          <div class="fable-section-head">
            <span>Lane Priority Matrix</span>
            <strong>新鲜度 × 知识深度 × 股票池宽度</strong>
          </div>
          <div class="matrix-stage" aria-label="Lane priority scatter plot">
            <svg viewBox="0 0 920 520" role="img" aria-label="车道优先级散点图">
              <defs>
                <pattern id="fableGrid" width="46" height="46" patternUnits="userSpaceOnUse">
                  <path d="M 46 0 L 0 0 0 46" fill="none" stroke="currentColor" stroke-width="1" opacity="0.13" />
                </pattern>
              </defs>
              <rect x="0" y="0" width="920" height="520" fill="url(#fableGrid)" />
              <line x1="70" y1="450" x2="850" y2="450" class="axis-line" />
              <line x1="70" y1="450" x2="70" y2="58" class="axis-line" />
              <text x="460" y="492" class="axis-title" text-anchor="middle">知识深度 / KB Depth</text>
              <text x="24" y="254" class="axis-title" text-anchor="middle" transform="rotate(-90 24 254)">论点新鲜度 / Freshness</text>
              {lanes.map((lane, index) => {
                const x = 70 + (lane.kb / 100) * 780;
                const y = 450 - (lane.freshness / 100) * 392;
                const r = 13 + (lane.stocks.length / maxLaneStocks) * 18;
                return (
                  <a href={`#${lane.id}`} class={`lane-dot tone-${lane.tone}`} data-lane={lane.id} style={`--delay:${index * 42}ms`}>
                    <circle cx={x} cy={y} r={r}>
                      <title>{lane.id} · {lane.label} · Priority {lane.priority}</title>
                    </circle>
                    <text x={x} y={y + 4} text-anchor="middle">{lane.id}</text>
                  </a>
                );
              })}
            </svg>
            <div class="matrix-legend">
              <span>右上：可执行且知识足</span>
              <span>左上：动作急但知识缺</span>
              <span>右下：知识足但非当下</span>
              <span>左下：期权/观察</span>
            </div>
          </div>
        </article>

        <aside class="fable-panel lane-inspector" id="laneInspector">
          <div class="fable-section-head">
            <span>Lane Inspector</span>
            <strong id="laneInspectorTitle">L01 · AI 电力链</strong>
          </div>
          <p id="laneInspectorStance">三项全满，但 QA 口径未闭合且短期拥挤退潮。</p>
          <div class="inspector-bars">
            <label>新鲜度<i><b id="laneFreshnessBar" style="width:94%"></b></i><strong id="laneFreshnessValue">94</strong></label>
            <label>KB 深度<i><b id="laneKbBar" style="width:96%"></b></i><strong id="laneKbValue">96</strong></label>
          </div>
          <div class="signal-note" id="laneSignal">GOES 215 次，110 买 / 45 卖；FERC 141 次</div>
          <div class="stock-chip-row" id="laneStocks">
            {lanes[0].stocks.map((ticker) => <a href={stockHref(ticker)}>{ticker}</a>)}
          </div>
        </aside>
      </section>

      <section class="fable-panel">
        <div class="fable-section-head">
          <span>Thesis Ledger</span>
          <strong>{thesisNodes.length} 条活论点 · {deadTheses.length} 条墓地样本</strong>
        </div>
        <div class="ledger-toolbar">
          <input id="fableSearch" type="search" placeholder="搜索论点、车道、股票、风险触发器..." />
          {statusCounts.map(([status, count]) => <button type="button" data-status={status}>{status}<strong>{count}</strong></button>)}
          <button type="button" data-status="">全部</button>
        </div>
        <div class="thesis-ribbon" aria-label="Thesis timeline">
          {thesisNodes.map((item, index) => (
            <a
              id={item.id}
              href={`#${item.lane}`}
              class={`thesis-node tone-${item.tone}`}
              data-status={item.status}
              data-search={`${item.id} ${item.title} ${item.status} ${item.lane} ${item.summary} ${item.trigger}`}
              style={`--score:${item.score}%; --delay:${index * 36}ms`}
            >
              <span>{item.id} · {item.start} → {item.end}</span>
              <strong>{item.title}</strong>
              <p>{item.summary}</p>
              <em>{item.status} · {item.lane} · Score {item.score}</em>
            </a>
          ))}
        </div>
      </section>

      <section class="fable-grid-two">
        <article class="fable-panel">
          <div class="fable-section-head">
            <span>Portfolio Alignment</span>
            <strong>26 本书 vs 19 条活论点</strong>
          </div>
          <div class="alignment-strip">
            <div><span>现金</span><strong>$24.4M</strong><em>NAV $28.06M</em></div>
            <div><span>实际仓位</span><strong>13.0%</strong><em>谨慎的唯一宏观表达</em></div>
            <div><span>零表达</span><strong>T03</strong><em>大金融/猪周期缺席</em></div>
            <div><span>下个检验</span><strong>07-15</strong><em>中报验尸</em></div>
          </div>
          <div class="portfolio-panel-grid">
            {portfolioPanels.map((item) => (
              <article class={`portfolio-signal tone-${item.tone}`}>
                <span>{item.label}</span>
                <strong>{item.count}</strong>
                <h3>{item.title}</h3>
                <p>{item.detail}</p>
              </article>
            ))}
          </div>
        </article>

        <article class="fable-panel">
          <div class="fable-section-head">
            <span>Action Queue</span>
            <strong>从复盘到执行的十个动作</strong>
          </div>
          <div class="action-queue">
            {actionItems.map(([rank, title, badge, tone]) => (
              <a href="#portfolio-actions" class={`action-item tone-${tone}`}>
                <span>{rank}</span>
                <strong>{title}</strong>
                <em>{badge}</em>
              </a>
            ))}
          </div>
        </article>
      </section>

      <section class="fable-panel">
        <div class="fable-section-head">
          <span>Lane Heat Table</span>
          <strong>优先级、信号、股票池与执行姿态</strong>
        </div>
        <div class="lane-table">
          {lanes.map((lane) => (
            <article id={lane.id} class={`lane-row tone-${lane.tone}`} data-lane={lane.id} data-search={`${lane.id} ${lane.label} ${lane.signal} ${lane.stance} ${lane.stocks.join(" ")}`}>
              <a class="lane-row-main" href={`#${lane.id}`}>
                <span>#{lane.priority} · {lane.id}</span>
                <strong>{lane.label}</strong>
                <em>{lane.stance}</em>
              </a>
              <div class="lane-metrics">
                <span>Fresh <b style={`width:${lane.freshness}%`}></b><strong>{lane.freshness}</strong></span>
                <span>KB <b style={`width:${lane.kb}%`}></b><strong>{lane.kb}</strong></span>
              </div>
              <div class="lane-signal">{lane.signal}</div>
              <div class="stock-chip-row compact">
                {lane.stocks.slice(0, 8).map((ticker) => <a href={stockHref(ticker)}>{ticker}</a>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="fable-grid-two">
        <article class="fable-panel">
          <div class="fable-section-head">
            <span>Dead Thesis Graveyard</span>
            <strong>弃案也是 alpha</strong>
          </div>
          <div class="graveyard">
            {deadTheses.map(([id, title, date, reason]) => (
              <article>
                <span>{id} · {date}</span>
                <strong>{title}</strong>
                <p>{reason}</p>
              </article>
            ))}
          </div>
        </article>

        <article class="fable-panel">
          <div class="fable-section-head">
            <span>Active Disputes</span>
            <strong>还没有被市场裁决的矛盾</strong>
          </div>
          <ol class="dispute-list">
            {disputes.map((item) => <li>{item}</li>)}
          </ol>
        </article>
      </section>

      <section class="fable-panel method-panel">
        <div class="fable-section-head">
          <span>Method & Limits</span>
          <strong>公开展示口径</strong>
        </div>
        <div class="method-grid">
          <div>
            <h2>挖掘方法</h2>
            <p>按时间与报告类型分桶精读，再将论点、主线、股票池、预测流主题信号和组合持仓做语义合并。页面保留被证伪论点、主动分歧与组合错配，因为这些是下一轮研究和执行改进的核心线索。</p>
          </div>
          <div>
            <h2>已知局限</h2>
            <p>5 月中至 6 月中周报覆盖存在簇状缺口；预测流中含主题缩写与伪 ticker，需要在组合管道中加校验门；本文展示的是合成层结果，不直接公开内部原始工作流对象。</p>
          </div>
        </div>
      </section>
    </main>

    <script id="fable-lanes" type="application/json" is:inline set:html={serializedLanes}></script>
    <script id="fable-theses" type="application/json" is:inline set:html={serializedTheses}></script>
    <script id="fable-public-stocks" type="application/json" is:inline set:html={serializedPublicStocks}></script>
    <script>
      const lanes = JSON.parse(document.getElementById("fable-lanes")?.textContent || "[]");
      const publicStocks = new Set(JSON.parse(document.getElementById("fable-public-stocks")?.textContent || "[]"));
      const laneById = new Map(lanes.map((lane) => [lane.id, lane]));
      const inspector = {
        title: document.getElementById("laneInspectorTitle"),
        stance: document.getElementById("laneInspectorStance"),
        signal: document.getElementById("laneSignal"),
        stocks: document.getElementById("laneStocks"),
        freshnessBar: document.getElementById("laneFreshnessBar"),
        kbBar: document.getElementById("laneKbBar"),
        freshnessValue: document.getElementById("laneFreshnessValue"),
        kbValue: document.getElementById("laneKbValue"),
      };

      function stockHref(ticker) {
        const clean = String(ticker || "").trim().toUpperCase().replace(/[^A-Z0-9.:-]+/g, "-").replace(/^-+|-+$/g, "");
        return publicStocks.has(ticker) ? `/investor/stocks/${clean || "UNKNOWN"}/` : `/investor/research-network/?q=${encodeURIComponent(ticker)}`;
      }

      function selectLane(id) {
        const lane = laneById.get(id);
        if (!lane) return;
        document.querySelectorAll("[data-lane]").forEach((node) => {
          node.classList.toggle("is-selected", node.dataset.lane === id);
        });
        inspector.title.textContent = `${lane.id} · ${lane.label}`;
        inspector.stance.textContent = lane.stance;
        inspector.signal.textContent = lane.signal;
        inspector.freshnessBar.style.width = `${lane.freshness}%`;
        inspector.kbBar.style.width = `${lane.kb}%`;
        inspector.freshnessValue.textContent = lane.freshness;
        inspector.kbValue.textContent = lane.kb;
        inspector.stocks.innerHTML = lane.stocks.map((ticker) => `<a href="${stockHref(ticker)}">${ticker}</a>`).join("");
      }

      document.querySelectorAll("[data-lane]").forEach((node) => {
        node.addEventListener("click", () => selectLane(node.dataset.lane));
        node.addEventListener("mouseenter", () => selectLane(node.dataset.lane));
      });

      const search = document.getElementById("fableSearch");
      let statusFilter = "";
      function applyFilters() {
        const q = (search?.value || "").trim().toLowerCase();
        document.querySelectorAll("[data-search]").forEach((node) => {
          const haystack = String(node.dataset.search || "").toLowerCase();
          const status = node.dataset.status || "";
          const visible = (!q || haystack.includes(q)) && (!statusFilter || status === statusFilter);
          node.hidden = !visible;
        });
      }
      search?.addEventListener("input", applyFilters);
      document.querySelectorAll("[data-status]").forEach((button) => {
        button.addEventListener("click", () => {
          statusFilter = button.dataset.status || "";
          document.querySelectorAll("[data-status]").forEach((item) => item.classList.toggle("is-active", item === button));
          applyFilters();
        });
      });
      selectLane("L01");
    </script>
  </body>
</html>
