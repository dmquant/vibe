---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import { readMarketOntology, readOddsBoard, readResearchNetwork, readWeeklyReport } from "../../../lib/investor-generated.js";
import { oddsLine, probabilityLabel, signedPoints, stockPath, thesisPath } from "../../../lib/investor-market.js";
import "../../../styles/research-network.css";
import "../../../styles/odds-board.css";

const network = readResearchNetwork();
const ontology = readMarketOntology();
const odds = readOddsBoard();
const weekly = readWeeklyReport();
const weeklyBook = weekly.weeklyPortfolio || { holdings: [], laneWeights: [], count: 0, totalWeightPct: 0 };
const theses = network.theses || [];
const stocks = [...(ontology.stocks || [])].sort((a, b) => Number(b.evidenceCount || 0) - Number(a.evidenceCount || 0) || a.ticker.localeCompare(b.ticker));
const lanes = ontology.lanes || [];
const laneById = new Map(lanes.map((lane) => [lane.id, lane]));
const adviceLanes = lanes.filter((lane) => lane.advice).sort((a, b) => Number(b.advice.confidence || 0) - Number(a.advice.confidence || 0));
const markets = [...new Set(stocks.map((stock) => stock.market).filter(Boolean))].sort();
const buckets = [...theses.reduce((acc, thesis) => {
  const bucket = thesis.practical?.exposureBucket || "主题机会";
  acc.set(bucket, (acc.get(bucket) || 0) + 1);
  return acc;
}, new Map()).entries()].sort((a, b) => b[1] - a[1]);
const actions = [...theses.reduce((acc, thesis) => {
  const action = thesis.practical?.actionLabel || "观察等待";
  acc.set(action, (acc.get(action) || 0) + 1);
  return acc;
}, new Map()).entries()].sort((a, b) => b[1] - a[1]);
const stanceLabels = { overweight: "超配", selective: "精选", neutral: "中性", underweight: "低配", avoid: "回避" };
const roleLabels = { core: "核心", watch: "观察", hedge: "对冲" };
const topLaneOdds = (odds.laneLines || []).slice(0, 12);
const topThesisOdds = (odds.thesisLines || []).slice(0, 18);
const portfolioData = JSON.stringify({
  stocks: stocks.map((stock) => ({ ticker: stock.ticker, name: stock.name, market: stock.market, href: stock.href, laneIds: stock.laneIds || [] })),
  lanes: lanes.map((lane) => ({ id: lane.id, titleZh: lane.titleZh, titleEn: lane.titleEn, href: lane.href, advice: lane.advice || null })),
  weeklyBook: {
    weekId: weekly.weekId,
    holdings: (weeklyBook.holdings || []).map((holding) => ({
      ticker: holding.ticker,
      weightPct: holding.weightPct,
      stance: holding.stance,
      stanceLabel: holding.stanceLabel,
      lane: holding.lanes?.[0]?.lane || "",
    })),
  },
}).replaceAll("<", "\\u003c");
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
  <head>
    <BaseHead
      title="组合工作台 · AI Institute"
      description="Browser-local thesis and stock portfolio workbench with validated lane research views."
    />
  </head>
  <body>
    <Header />
    <main class="research-network portfolio-page">
      <section class="network-hero portfolio-hero">
        <div>
          <div class="network-kicker">AI Institute · Portfolio Workbench</div>
          <h1>组合工作台</h1>
          <p>从研究主线进入赛道和股票簿：模型负责生成可证伪的赛道观点，市值、成本、盈亏与暴露由本地确定性账本计算。</p>
          <div class="network-actions">
            <a href="/investor/">研究台</a>
            <a href="/investor/research-network/">研究网络</a>
            <a href="/investor/recaps/">复盘</a>
          </div>
        </div>
        <aside class="network-privacy">
          <span>Local Research Book</span>
          <p>仓位、价格、汇率因子和备注只保存在当前浏览器；静态站点不连接账户，也不上传持仓。</p>
        </aside>
      </section>

      <section class="network-stat-grid" aria-label="Portfolio coverage">
        <div><span>Stocks</span><strong>{stocks.length}</strong><em>公开标的节点</em></div>
        <div><span>Theses</span><strong>{theses.length}</strong><em>可追踪主线</em></div>
        <div><span>Model Views</span><strong>{adviceLanes.length}</strong><em>已验证赛道观点</em></div>
        <div><span>Local Book</span><strong><b data-count-stocks>0</b> / <b data-count-theses>0</b></strong><em>股票 / thesis</em></div>
      </section>

      <section class="portfolio-command-bar" aria-label="Portfolio controls">
        <div class="portfolio-mode-tabs" role="tablist" aria-label="Portfolio views">
          <button type="button" data-view-target="stocks" role="tab">股票簿 <b data-count-stocks>0</b></button>
          <button type="button" data-view-target="theses" role="tab">Thesis Book <b data-count-theses>0</b></button>
          <button type="button" data-view-target="weekly" role="tab">周度百股 <b>{weeklyBook.count || 0}</b></button>
          <button type="button" data-view-target="odds" role="tab">Odds Book <b>{odds.coverage?.shadowPricedTheses || 0}</b></button>
          <button type="button" data-view-target="advice" role="tab">模型赛道观点 <b>{adviceLanes.length}</b></button>
        </div>
        <div class="portfolio-toolbar">
          <button type="button" id="importPortfolioButton">导入 JSON</button>
          <input id="importPortfolio" type="file" accept="application/json,.json" hidden />
          <button type="button" id="exportPortfolio">导出 JSON</button>
          <button type="button" id="clearPortfolio" class="is-danger">清空本地账本</button>
        </div>
      </section>

      <div data-portfolio-view="stocks">
        <section class="portfolio-ledger-layout">
          <article class="portfolio-panel is-large">
            <div class="section-mini-head"><span>Stock Book</span><strong>股票持仓与观察簿</strong></div>
            <div class="stock-book-summary" id="stockPortfolioSummary"></div>
            <div class="portfolio-list full" id="stockPortfolioList" aria-live="polite"></div>
          </article>
          <aside class="portfolio-panel portfolio-accounting">
            <div class="section-mini-head"><span>Exposure</span><strong>赛道暴露</strong></div>
            <label class="filter-control">基础币种
              <select id="portfolioBaseCurrency">
                <option value="USD">USD</option><option value="CNY">CNY</option><option value="HKD">HKD</option><option value="EUR">EUR</option>
              </select>
            </label>
            <div class="allocation-board" id="laneExposureBoard"></div>
          </aside>
        </section>

        <section class="thesis-section">
          <div class="section-headline">
            <span>Stock Universe</span>
            <h2>公开股票节点</h2>
            <p>按研究证据排序，股票名称、赛道和来源均来自公开市场本体。</p>
          </div>
          <div class="stock-pool-toolbar">
            <label class="filter-control">搜索
              <input id="stockSearch" type="search" placeholder="Ticker、公司、赛道、研究角色" />
            </label>
            <label class="filter-control">市场
              <select id="stockMarketFilter"><option value="">全部市场</option>{markets.map((market) => <option value={market}>{market}</option>)}</select>
            </label>
          </div>
          <div class="stock-candidate-grid">
            {stocks.map((stock) => {
              const stockLanes = (stock.laneIds || []).map((id) => laneById.get(id)).filter(Boolean);
              return (
                <article class="stock-candidate" data-market={stock.market} data-search={`${stock.ticker} ${stock.name} ${stock.market} ${(stock.roles || []).join(" ")} ${stockLanes.map((lane) => lane.titleZh).join(" ")}`}>
                  <a href={stock.href || stockPath(stock)}>
                    <span>{stock.market} · {stock.evidenceCount || 0} evidence</span>
                    <strong>{stock.ticker}</strong>
                    <em>{stock.name}</em>
                  </a>
                  <div>{stockLanes.slice(0, 3).map((lane) => <a href={lane.href}>{lane.titleZh}</a>)}</div>
                  <button type="button" data-add-stock={stock.ticker}>加入股票簿</button>
                </article>
              );
            })}
          </div>
        </section>
      </div>

      <div data-portfolio-view="weekly" hidden>
        <section class="thesis-section weekly-book-view">
          <div class="section-headline">
            <span>Weekly A-share Research Book · {weekly.weekId}</span>
            <h2>A股百股研究组合</h2>
            <p>{weeklyBook.methodology || "按公开证据、主线连接、赛道位置、时效和 stance 生成确定性周度研究组合。"}</p>
          </div>
          <div class="weekly-book-command">
            <div>
              <span>{weeklyBook.count || 0} A-share equities</span>
              <strong>{Number(weeklyBook.totalWeightPct || 0).toFixed(2)}%</strong>
              <em>research weight · non-executable</em>
            </div>
            <button type="button" data-add-weekly-book>加入本地股票簿</button>
            <a href="/investor/panorama/#a-share-book">查看周度论证</a>
          </div>
          <div class="weekly-book-lanes" aria-label="Weekly lane exposure">
            {(weeklyBook.laneWeights || []).slice(0, 10).map((lane, index) => (
              <a href={lane.href}>
                <span>#{index + 1}</span>
                <strong>{lane.lane}</strong>
                <i><b style={`width:${Math.min(100, Math.max(4, Number(lane.weightPct || 0) * 5))}%`}></b></i>
                <em>{Number(lane.weightPct || 0).toFixed(2)}% · {lane.stockCount} stocks</em>
              </a>
            ))}
          </div>
          <div class="weekly-book-table" role="table" aria-label="Weekly A-share research portfolio">
            <div class="weekly-book-row is-head" role="row">
              <span>Rank</span><span>Stock</span><span>Stance</span><span>Primary lane</span><span>Evidence</span><span>Weight</span><span>Action</span>
            </div>
            {(weeklyBook.holdings || []).map((holding) => (
              <article class={`weekly-book-row stance-${holding.stance}`} role="row">
                <span>{String(holding.rank).padStart(3, "0")}</span>
                <a href={holding.href}><strong>{holding.ticker}</strong><em>{holding.name}</em></a>
                <span><strong>{holding.stanceLabel}</strong><em>{holding.researchScore} score</em></span>
                <span>{holding.lanes?.[0]?.lane || "待映射"}</span>
                <span>{holding.evidenceCount} evidence · {holding.thesisCount} theses</span>
                <span><strong>{Number(holding.weightPct || 0).toFixed(2)}%</strong></span>
                <button
                  type="button"
                  data-add-stock={holding.ticker}
                  data-weekly-weight={holding.weightPct}
                  data-weekly-stance={holding.stance}
                  data-weekly-lane={holding.lanes?.[0]?.lane || ""}
                >加入</button>
              </article>
            ))}
          </div>
          <p class="portfolio-disclaimer">{weeklyBook.disclaimer || "该组合用于研究排序与周度复核，不是交易指令、投资建议或收益承诺。"}</p>
        </section>
      </div>

      <div data-portfolio-view="theses" hidden>
        <section class="portfolio-workbench">
          <article class="portfolio-panel is-large">
            <div class="section-mini-head"><span>Thesis Book</span><strong>主线配置视图</strong></div>
            <div class="portfolio-summary" id="thesisPortfolioSummary">当前 thesis book 为空。</div>
            <div class="allocation-board" id="thesisAllocationBoard"></div>
            <div class="portfolio-list full" id="thesisPortfolioList" aria-live="polite"></div>
          </article>
          <aside class="portfolio-panel">
            <div class="section-mini-head"><span>Filters</span><strong>筛选研究主线</strong></div>
            <label class="filter-control">搜索<input id="thesisSearch" type="search" placeholder="主线、标的、风险、动作" /></label>
            <div class="bucket-stack compact">
              <button type="button" data-thesis-bucket="">全部暴露</button>
              {buckets.map(([bucket, count]) => <button type="button" data-thesis-bucket={bucket}>{bucket}<strong>{count}</strong></button>)}
            </div>
            <div class="action-stack compact">
              <button type="button" data-thesis-action="">全部动作</button>
              {actions.map(([action, count]) => <button type="button" data-thesis-action={action}>{action}<strong>{count}</strong></button>)}
            </div>
          </aside>
        </section>

        <section class="thesis-section">
          <div class="section-headline">
            <span>Candidate Thesis Pool</span>
            <h2>研究主线候选池</h2>
            <p>主线包含赛道、股票映射、确认信号、证伪条件和风险预算。</p>
          </div>
          <div class="portfolio-candidate-list">
            {theses.map((thesis) => (
              <article class="candidate-row" data-search={`${thesis.title} ${thesis.coreView} ${thesis.lane || ""} ${(thesis.stockTickers || []).join(" ")} ${(thesis.stockUniverse || []).map((stock) => stock.name).join(" ")} ${thesis.practical?.exposureBucket || ""} ${thesis.practical?.actionLabel || ""}`} data-bucket={thesis.practical?.exposureBucket || "主题机会"} data-action={thesis.practical?.actionLabel || "观察等待"}>
                <div>
                  <span>{thesis.lane || thesis.practical?.sectorLane || "主题机会"} · {thesis.practical?.portfolioRole || thesis.practical?.actionLabel || "观察"} · Score {thesis.practical?.score || thesis.conviction}</span>
                  <h3><a href={thesisPath(thesis)}>{thesis.title}</a></h3>
                  <p>{thesis.practical?.portfolioUse || thesis.coreView}</p>
                  <div class="portfolio-detail-grid">
                    <span><strong>动作</strong>{thesis.practical?.actionLabel || "观察等待"}</span>
                    <span><strong>风险预算</strong>{thesis.practical?.weightGuide || thesis.practical?.riskBudget || "观察仓"}</span>
                    <span><strong>期限</strong>{thesis.practical?.timeHorizon || thesis.practical?.reviewCadence || "待定"}</span>
                    <span><strong>证据</strong>{thesis.eventCount || 0} events</span>
                  </div>
                  <div class="stock-chip-row compact">
                    {(thesis.stockUniverse || []).slice(0, 8).map((stock) => <a href={stock.href || stockPath(stock)}><strong>{stock.ticker}</strong><span>{stock.market}</span></a>)}
                  </div>
                  <details>
                    <summary>确认、证伪与下一步研究</summary>
                    <div class="signal-grid">
                      <div><strong>确认</strong>{(thesis.practical?.confirmationSignals || []).slice(0, 3).map((item) => <p>{item}</p>)}</div>
                      <div><strong>证伪</strong>{(thesis.practical?.invalidationSignals || []).slice(0, 3).map((item) => <p>{item}</p>)}</div>
                    </div>
                  </details>
                </div>
                <aside>
                  <span>{thesis.practical?.portfolioRole || thesis.practical?.actionLabel || "观察"}</span>
                  <span>{thesis.practical?.weightGuide || thesis.practical?.riskBudget}</span>
                  <button type="button" class="track-thesis" data-track-id={thesis.id} data-track-title={thesis.title} data-track-bucket={thesis.practical?.exposureBucket || "主题机会"} data-track-action={thesis.practical?.actionLabel || "观察等待"} data-track-score={thesis.practical?.score || thesis.conviction || 0} data-track-risk={thesis.practical?.weightGuide || thesis.practical?.riskBudget || ""}>加入 Thesis Book</button>
                </aside>
              </article>
            ))}
          </div>
        </section>
      </div>

      <div data-portfolio-view="odds" hidden class="odds-board odds-book-view">
        <section class="thesis-section">
          <div class="section-headline">
            <span>Shadow Odds Book</span>
            <h2>赔率簿：先比较判断，再决定是否下注</h2>
            <p>当前只发布证据驱动 house probability。p_market、payoff、EV、动态 Kelly 与真实仓位均未启用。</p>
          </div>
          <div class="odds-book-status">
            <span><strong>{odds.coverage?.shadowPricedTheses || 0}</strong> thesis contracts</span>
            <span><strong>{odds.coverage?.laneIndices || 0}</strong> lane indices</span>
            <span><strong>{odds.coverage?.settlements || 0}</strong> settlements</span>
            <span><strong>OFF</strong> dynamic Kelly</span>
            <a href="/investor/odds/">打开完整赔率盘</a>
          </div>
          <div class="odds-book-columns">
            <article>
              <div class="section-mini-head"><span>Lane sub-book</span><strong>赛道成员隐含</strong></div>
              <div class="odds-lane-grid odds-book-lanes">
                {topLaneOdds.map((item) => (
                  <a class="odds-lane-card" href={item.href}>
                    <header><span>{item.pricingStateLabel}</span><em>{item.memberCount} contracts</em></header>
                    <h3>{item.title}</h3>
                    <div class="odds-mini-curve">
                      {item.termStructure.map((quote) => (
                        <span data-h={quote.horizon}><em>{quote.horizon.toUpperCase()}</em><strong>{probabilityLabel(quote.pHouse)}</strong><i><b style={`width:${quote.pHousePct}%`}></b></i></span>
                      ))}
                    </div>
                    <footer><span>{item.curve?.labelZh} · {signedPoints(item.curve?.slopePp)}</span><em>Kelly OFF</em></footer>
                  </a>
                ))}
              </div>
            </article>
            <article>
              <div class="section-mini-head"><span>Contract sub-book</span><strong>20D 主线排序</strong></div>
              <div class="odds-book-contract-list">
                {topThesisOdds.map((item) => (
                  <a href={item.href}>
                    <span>{item.lane} · {item.curve?.labelZh}</span>
                    <strong>{item.title}</strong>
                    <em>5D {probabilityLabel(oddsLine(item, "5d")?.pHouse)} · 20D {probabilityLabel(oddsLine(item, "20d")?.pHouse)} · 60D {probabilityLabel(oddsLine(item, "60d")?.pHouse)} · conf {item.confidence?.score}</em>
                  </a>
                ))}
              </div>
            </article>
          </div>
          <p class="portfolio-disclaimer">影子赔率仅用于研究排序。没有 market edge 和 payoff 时，Kelly 为不可计算，不应以 house probability 代替仓位建议。</p>
        </section>
      </div>

      <div data-portfolio-view="advice" hidden>
        <section class="thesis-section model-advice-section">
          <div class="section-headline">
            <span>Validated Model Views</span>
            <h2>LLM 赛道投资观点</h2>
            <p>每条观点都经过允许标的、公开来源、配置区间和证伪条件校验；观点不直接修改本地价格或仓位。</p>
          </div>
          <div class="lane-advice-grid">
            {adviceLanes.map((lane) => (
              <article
                class={`lane-advice-card stance-${lane.advice.stance}`}
                data-research-href={lane.href}
                tabindex="0"
                role="link"
                aria-label={`打开${lane.titleZh}赛道详情`}
              >
                <header>
                  <div><span>{stanceLabels[lane.advice.stance] || lane.advice.stance} · {lane.advice.horizon}</span><h3><a href={lane.href}>{lane.titleZh}</a></h3></div>
                  <strong>{lane.advice.confidence}<em>confidence</em></strong>
                </header>
                <p>{lane.advice.summaryZh}</p>
                <div class="advice-range"><span>研究配置区间</span><strong>{lane.advice.allocationRangePct.min}%–{lane.advice.allocationRangePct.max}%</strong><i><b style={`width:${lane.advice.allocationRangePct.max * 4}%`}></b></i></div>
                <div class="advice-basket">
                  {lane.advice.basket.map((item) => (
                    <a href={stockPath(item.ticker)}><span>{roleLabels[item.role] || item.role}</span><strong>{item.ticker}</strong><em>{item.suggestedWeightPct}%</em><p>{item.rationaleZh}</p></a>
                  ))}
                </div>
                <details>
                  <summary>催化剂、风险、证伪与来源</summary>
                  <div class="advice-detail-grid">
                    <div><strong>催化剂</strong>{lane.advice.catalystsZh.map((item) => <p>{item}</p>)}</div>
                    <div><strong>风险</strong>{lane.advice.risksZh.map((item) => <p>{item}</p>)}</div>
                    <div><strong>证伪</strong>{lane.advice.falsifiersZh.map((item) => <p>{item}</p>)}</div>
                    <div><strong>仓位纪律</strong>{lane.advice.sizingRulesZh.map((item) => <p>{item}</p>)}</div>
                  </div>
                  <div class="advice-sources">{lane.advice.reportRefs.map((report) => <a href={report.href}>{report.date} · {report.title}</a>)}</div>
                </details>
                <footer><span>{lane.advice.asOfDate} · {lane.advice.provenance.model}</span><button type="button" data-add-basket={lane.id}>加入股票簿</button></footer>
              </article>
            ))}
          </div>
          <p class="portfolio-disclaimer">模型观点用于研究排序与情景管理，不构成交易指令；价格、汇率、仓位和盈亏由用户在本地账本维护。</p>
        </section>
      </div>
    </main>

    <script id="portfolioData" type="application/json" set:html={portfolioData}></script>
    <script src="../../../scripts/portfolio-workbench.js"></script>
  </body>
</html>
