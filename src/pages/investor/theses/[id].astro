---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import OddsSurface from "../../../components/investor/OddsSurface.astro";
import { readOddsBoard, readResearchNetwork } from "../../../lib/investor-generated.js";
import { buildLaneIndex, buildOddsIndexes, buildStockIndex, formatDate, lanePath, mappingSourceLabel, pct, stockPath, thesisPath } from "../../../lib/investor-market.js";
import "../../../styles/research-network.css";

export function getStaticPaths() {
  const network = readResearchNetwork();
  const theses = network.theses || [];
  const lanes = buildLaneIndex(network);
  const stocks = buildStockIndex(network);
  const odds = buildOddsIndexes(readOddsBoard()).theses;
  return theses.map((thesis) => ({
    params: { id: thesis.id },
    props: {
      thesis,
      oddsSurface: odds.get(thesis.id) || null,
      lane: lanes.find((item) => item.slug === (thesis.laneHref || lanePath(thesis)).split("/").filter(Boolean).at(-1)),
      relatedStocks: stocks.filter((stock) => (thesis.stockUniverse || []).some((item) => item.ticker === stock.ticker)),
    },
  }));
}

const { thesis, lane, relatedStocks, oddsSurface } = Astro.props;
const events = (thesis.timeline || []).flatMap((group) => (group.events || []).map((event) => ({ ...event, date: group.date }))).slice(0, 18);
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
  <head>
    <BaseHead
      title={`${thesis.title} · AI Institute Thesis`}
      description={thesis.coreView || "AI Institute thesis detail with lane, stock universe, and evidence timeline."}
    />
  </head>
  <body>
    <Header />
    <main class="research-network detail-page">
      <section class="network-hero">
        <div>
          <div class="network-kicker">AI Institute · Thesis</div>
          <h1>{thesis.title}</h1>
          <p>{thesis.coreView}</p>
          <div class="network-actions">
            <a href="/investor/research-network/">研究网络</a>
            <a href="/investor/odds/">赔率盘</a>
            <a href={lanePath(thesis)}>{thesis.lane || thesis.practical?.sectorLane || "赛道页"}</a>
            <a href="/investor/portfolio/">加入组合台</a>
          </div>
        </div>
        <aside class="network-privacy">
          <span>{thesis.directionLabel}</span>
          <p>{thesis.investableFocus || thesis.practical?.portfolioUse || "候选标的仅用于研究跟踪，不构成交易建议。"}</p>
        </aside>
      </section>

      <section class="network-stat-grid">
        <div><span>Lane</span><strong>{thesis.lane || thesis.practical?.sectorLane || "未分类"}</strong><em>赛道</em></div>
        <div><span>Conviction</span><strong>{thesis.conviction}</strong><em>主线强度</em></div>
        <div><span>Evidence</span><strong>{thesis.eventCount}</strong><em>时间线事件</em></div>
        <div><span>Stocks</span><strong>{(thesis.stockUniverse || []).length}</strong><em>候选标的</em></div>
      </section>

      <OddsSurface
        surface={oddsSurface}
        title="主线合约赔率"
        description="该 thesis 股票篮子相对待映射基准的 5 / 20 / 60 交易日影子概率。"
      />

      <section class="detail-grid">
        <article class="detail-panel is-main">
          <div class="section-mini-head"><span>Mechanism</span><strong>主线定义</strong></div>
          <p>{thesis.practical?.portfolioUse || thesis.coreView}</p>
          <div class={`practical-callout tone-${thesis.practical?.actionTone || thesis.practical?.tone || "blue"}`}>
            <div>
              <span>{thesis.practical?.exposureBucket || "主题机会"}</span>
              <strong>{thesis.practical?.actionLabel || "观察等待"}</strong>
            </div>
            <a class="track-thesis" href="/investor/portfolio/">组合追踪</a>
          </div>
          <div class="portfolio-detail-grid">
            <span><strong>风险预算</strong>{thesis.practical?.weightGuide || thesis.practical?.riskBudget || "观察仓"}</span>
            <span><strong>复核节奏</strong>{thesis.practical?.reviewCadence || "待定"}</span>
            <span><strong>期限</strong>{thesis.practical?.timeHorizon || "待定"}</span>
            <span><strong>深研优先级</strong>{thesis.practical?.deepResearchPriority || "常规跟踪"}</span>
          </div>
        </article>
        <aside class="detail-panel">
          <div class="section-mini-head"><span>Evidence Mix</span><strong>证据结构</strong></div>
          <div class="thesis-meter"><i style={`width:${pct(thesis.conviction)}`}></i><strong>{thesis.conviction}</strong></div>
          <div class="thesis-counters">
            <span>支持 {thesis.supports}</span>
            <span>风险 {thesis.risks}</span>
            <span>观察 {thesis.neutral}</span>
            <span>分析师 {thesis.analystCount}</span>
          </div>
        </aside>
      </section>

      {(thesis.reportRefs || []).length > 0 && (
        <section class="thesis-section">
          <div class="section-headline">
            <span>Provenance</span>
            <h2>核心来源报告</h2>
            <p>主线、赛道与标的映射均可回到公开研究结果复核。</p>
          </div>
          <div class="event-stack detail-events">
            {thesis.reportRefs.slice(0, 8).map((report) => (
              <a href={report.href}>
                <span>{formatDate(report.date)} · SOURCE REPORT</span>
                <strong>{report.title}</strong>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="thesis-section">
        <div class="section-headline">
          <span>Stock Universe</span>
          <h2>候选标的池</h2>
          <p>这些股票、ETF 或 ADR 是研究跟踪入口，用于连接赛道、证据和组合动作。</p>
        </div>
        <div class="stock-cloud wide">
          {(thesis.stockUniverse || []).map((stock) => (
            <a href={stockPath(stock)}>
              <strong>{stock.ticker}</strong>
              <span>{stock.name}</span>
              <em>
                {stock.market} · {stock.role}
                {stock.mappingSource ? ` · ${mappingSourceLabel(stock.mappingSource)}` : ""}
                {Number(stock.evidenceCount || 0) > 0 ? ` · 证据 ${stock.evidenceCount}` : ""}
              </em>
            </a>
          ))}
        </div>
      </section>

      <section class="thesis-section">
        <div class="section-headline">
          <span>Timeline</span>
          <h2>证据时间线</h2>
          <p>支持、风险和观察事件按日期聚合，保留公共链接和来源标签。</p>
        </div>
        <div class="event-stack detail-events">
          {events.map((event) => (
            <a href={event.href || thesis.networkHref || thesisPath(thesis)}>
              <span>{formatDate(event.date)} · {event.sourceLabel} · {event.supportLabel}</span>
              <strong>{event.title}</strong>
              {event.summary && <em>{event.summary}</em>}
            </a>
          ))}
        </div>
      </section>

      {relatedStocks.length > 0 && (
        <section class="thesis-section">
          <div class="section-headline">
            <span>Cross Links</span>
            <h2>相关股票的其它主线</h2>
          </div>
          <div class="mini-thesis-list">
            {relatedStocks.flatMap((stock) => stock.theses.filter((item) => item.id !== thesis.id).slice(0, 3).map((item) => (
              <a href={thesisPath(item)}>
                <span>{stock.ticker} · {item.directionLabel}</span>
                <strong>{item.title}</strong>
                <em>{formatDate(item.lastSeen)}</em>
              </a>
            )))}
          </div>
        </section>
      )}
    </main>
  </body>
</html>
