---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import HundredDaysPortal from "../../components/hundred-days/HundredDaysPortal.astro";
import hundredDays from "../../generated/hundred-days/index.json";
import "../../styles/hundred-days.css";
---

<!doctype html>
<html lang="zh-CN" data-lang="zh">
  <head>
    <BaseHead
      title="AI 研究院的 100 天 · 一座会修正自己的研究机构"
      description="研究不是生成，是持续修正。回放 AI Institute 如何保存证据与分歧、接受人类质疑、复盘判断，并把研究映射到 thesis、赛道、股票和组合。"
    />
  </head>
  <body class="hundred-days-page">
    <Header />
    <HundredDaysPortal data={hundredDays} />
  </body>
</html>
