---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Brief posts (Morning Brief, Editor, Mailbox)
const briefEn = posts.filter(p => p.data.category === 'brief' && p.data.lang === 'en');
const briefZh = posts.filter(p => p.data.category === 'brief' && p.data.lang === 'zh');

// Classify brief types by slug prefix
const classifyBrief = (id: string) => {
	if (id.includes('editor-daily')) return 'editor';
	if (id.includes('mailbox-digest')) return 'mailbox';
	return 'morning';
};

const briefTypes = [
	{ key: 'morning', icon: '📋', en: 'Morning Brief', zh: '晨间简报', desc_en: '7-stage analyst pipeline', desc_zh: '7阶段分析师管线' },
	{ key: 'editor', icon: '⚖️', en: 'Editor Report', zh: '总编报告', desc_en: '4-phase contradiction sweep', desc_zh: '4阶段矛盾梳理' },
	{ key: 'mailbox', icon: '📬', en: 'Mailbox Digest', zh: '邮箱摘要', desc_en: 'Cross-desk exchanges', desc_zh: '跨部门交流' },
];

// Get latest brief of each type
const latestBriefsEn = briefTypes.map(t => ({
	...t,
	post: briefEn.find(p => classifyBrief(p.id) === t.key) || null,
}));
const latestBriefsZh = briefTypes.map(t => ({
	...t,
	post: briefZh.find(p => classifyBrief(p.id) === t.key) || null,
}));

// Group remaining content
const instituteEn = posts.filter(p => p.data.category === 'institute' && p.data.lang === 'en');
const instituteZh = posts.filter(p => p.data.category === 'institute' && p.data.lang === 'zh');
const researchEn = posts.filter(p => p.data.category === 'research' && p.data.lang === 'en');
const researchZh = posts.filter(p => p.data.category === 'research' && p.data.lang === 'zh');
const vibelogEn = posts.filter(p => p.data.category === 'vibelog' && p.data.lang === 'en');
const vibelogZh = posts.filter(p => p.data.category === 'vibelog' && p.data.lang === 'zh');

// Brief archive (all briefs, grouped by date)
const briefDatesEn = new Map<string, typeof briefEn>();
briefEn.forEach(p => {
	const date = p.data.pubDate.toISOString().split('T')[0];
	if (!briefDatesEn.has(date)) briefDatesEn.set(date, []);
	briefDatesEn.get(date)!.push(p);
});
const briefDatesZh = new Map<string, typeof briefZh>();
briefZh.forEach(p => {
	const date = p.data.pubDate.toISOString().split('T')[0];
	if (!briefDatesZh.has(date)) briefDatesZh.set(date, []);
	briefDatesZh.get(date)!.push(p);
});
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Compact Hero Banner -->
			<section class="hero-banner">
				<div class="hero-inner">
					<div class="hero-left">
						<h1>Research<span class="accent">OS</span></h1>
						<p class="hero-tagline" data-en="Multi-agent autonomous research · 42 AI analysts · Daily briefs" data-zh="多智能体自主研究 · 42位AI分析师 · 每日简报">
							Multi-agent autonomous research · 42 AI analysts · Daily briefs
						</p>
					</div>
					<div class="hero-right">
						<div class="hero-stats-inline">
							<span class="stat-pill"><strong>42</strong> <em data-en="analysts" data-zh="分析师">analysts</em></span>
							<span class="stat-pill"><strong>1,062+</strong> <em data-en="reports" data-zh="报告">reports</em></span>
							<span class="stat-pill"><strong>50+</strong> <em data-en="sessions" data-zh="研讨">sessions</em></span>
						</div>
						<div class="hero-links">
							<a href="/blog" class="btn btn-sm btn-primary" data-en="All Articles" data-zh="全部文章">All Articles</a>
							<a href="https://github.com/dmquant/vibe" class="btn btn-sm btn-ghost" target="_blank">GitHub →</a>
						</div>
					</div>
				</div>
			</section>

			<!-- ═══════════════════════════════════════════════════════════ -->
			<!-- Latest Daily Briefs — the primary content                 -->
			<!-- ═══════════════════════════════════════════════════════════ -->
			<section class="section briefs-section">
				<div class="section-header">
					<h2 data-en="📰 Latest Daily Briefs" data-zh="📰 最新每日简报">📰 Latest Daily Briefs</h2>
					<span class="section-badge live-badge" data-en="Auto-generated" data-zh="自动生成">Auto-generated</span>
				</div>

				<!-- EN Briefs -->
				<div class="brief-grid lang-content" data-show-lang="en">
					{latestBriefsEn.map(({ icon, en, desc_en, post }) => (
						post ? (
							<a href={`/blog/${post.id}/`} class="brief-card">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{en}</span>
									<span class="brief-date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
								<h3>{post.data.title}</h3>
								<p class="brief-desc">{post.data.description}</p>
								<span class="brief-cta">Read full report →</span>
							</a>
						) : (
							<div class="brief-card brief-card-empty">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{en}</span>
								</div>
								<p class="brief-desc">{desc_en} — coming soon</p>
							</div>
						)
					))}
				</div>

				<!-- ZH Briefs -->
				<div class="brief-grid lang-content" data-show-lang="zh">
					{latestBriefsZh.map(({ icon, zh, desc_zh, post }) => (
						post ? (
							<a href={`/blog/${post.id}/`} class="brief-card">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{zh}</span>
									<span class="brief-date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
								<h3>{post.data.title}</h3>
								<p class="brief-desc">{post.data.description}</p>
								<span class="brief-cta">阅读完整报告 →</span>
							</a>
						) : (
							<div class="brief-card brief-card-empty">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{zh}</span>
								</div>
								<p class="brief-desc">{desc_zh} — 即将推出</p>
							</div>
						)
					))}
				</div>
			</section>

			<!-- Brief Archive -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="📅 Brief Archive" data-zh="📅 简报存档">📅 Brief Archive</h2>
				</div>

				<div class="archive-list lang-content" data-show-lang="en">
					{[...briefDatesEn.entries()].slice(0, 7).map(([date, datePosts]) => (
						<div class="archive-row">
							<span class="archive-date">{date}</span>
							<div class="archive-links">
								{datePosts.map(p => {
									const type = classifyBrief(p.id);
									const typeInfo = briefTypes.find(t => t.key === type);
									return (
										<a href={`/blog/${p.id}/`} class={`archive-tag tag-${type}`}>
											{typeInfo?.icon} {typeInfo?.en}
										</a>
									);
								})}
							</div>
						</div>
					))}
				</div>

				<div class="archive-list lang-content" data-show-lang="zh">
					{[...briefDatesZh.entries()].slice(0, 7).map(([date, datePosts]) => (
						<div class="archive-row">
							<span class="archive-date">{date}</span>
							<div class="archive-links">
								{datePosts.map(p => {
									const type = classifyBrief(p.id);
									const typeInfo = briefTypes.find(t => t.key === type);
									return (
										<a href={`/blog/${p.id}/`} class={`archive-tag tag-${type}`}>
											{typeInfo?.icon} {typeInfo?.zh}
										</a>
									);
								})}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Deep Research Papers -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="📊 Deep Research Papers" data-zh="📊 深度研究论文">📊 Deep Research Papers</h2>
					<span class="section-badge" data-en="Latest" data-zh="最新">Latest</span>
				</div>
				<div class="article-grid lang-content" data-show-lang="en">
					{researchEn.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card research-card">
							<div class="card-meta">
								<span class="lang-badge en">EN</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
				<div class="article-grid lang-content" data-show-lang="zh">
					{researchZh.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card research-card">
							<div class="card-meta">
								<span class="lang-badge zh">中文</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<!-- Institute Series -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="🏛️ The Institute Series" data-zh="🏛️ 智研所系列">🏛️ The Institute Series</h2>
					<span class="section-badge" data-en="6-Part Deep Dive" data-zh="6篇深度解析">6-Part Deep Dive</span>
				</div>
				<div class="series-list lang-content" data-show-lang="en">
					{instituteEn.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="series-item">
							<span class="series-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="series-content">
								<h4>{post.data.title}</h4>
								<p>{post.data.description}</p>
							</div>
							<span class="series-arrow">→</span>
						</a>
					))}
				</div>
				<div class="series-list lang-content" data-show-lang="zh">
					{instituteZh.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="series-item">
							<span class="series-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="series-content">
								<h4>{post.data.title}</h4>
								<p>{post.data.description}</p>
							</div>
							<span class="series-arrow">→</span>
						</a>
					))}
				</div>
			</section>

			<!-- Vibelog & Guides -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="📝 Vibelog & Guides" data-zh="📝 指南与文档">📝 Vibelog & Guides</h2>
				</div>
				<div class="article-grid lang-content" data-show-lang="en">
					{vibelogEn.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card">
							<div class="card-meta">
								<span class="lang-badge en">EN</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
				<div class="article-grid lang-content" data-show-lang="zh">
					{vibelogZh.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card">
							<div class="card-meta">
								<span class="lang-badge zh">中文</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />

		<script>
			function applyLang(lang: string) {
				document.querySelectorAll('.lang-content').forEach(el => {
					const showLang = (el as HTMLElement).dataset.showLang;
					(el as HTMLElement).style.display = showLang === lang ? '' : 'none';
				});
				document.querySelectorAll('[data-en][data-zh]').forEach(el => {
					const htmlEl = el as HTMLElement;
					const text = lang === 'zh' ? htmlEl.dataset.zh : htmlEl.dataset.en;
					if (text) htmlEl.textContent = text;
				});
			}
			const initialLang = localStorage.getItem('researchos-lang') || 'en';
			applyLang(initialLang);
			window.addEventListener('lang-change', (e: Event) => {
				const detail = (e as CustomEvent).detail;
				applyLang(detail.lang);
			});
		</script>
	</body>
</html>

<style>
	/* ═══ Compact Hero Banner ═══ */
	.hero-banner {
		border-bottom: 1px solid var(--border, #30363d);
		background: linear-gradient(180deg, rgba(88,166,255,0.04) 0%, transparent 100%);
		padding: 1.5rem 1rem;
	}
	.hero-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}
	.hero-left h1 {
		font-size: 2.2rem;
		font-weight: 800;
		margin: 0 0 0.25rem;
		letter-spacing: -0.02em;
	}
	.accent { color: var(--accent-cyan, #58a6ff); }
	.hero-tagline {
		color: var(--text-secondary, #8b949e);
		font-size: 0.88rem;
		margin: 0;
	}
	.hero-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.75rem;
	}
	.hero-stats-inline {
		display: flex;
		gap: 0.6rem;
	}
	.stat-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.2rem 0.6rem;
		background: var(--bg-surface, #161b22);
		border: 1px solid var(--border, #30363d);
		border-radius: 16px;
		font-size: 0.72rem;
	}
	.stat-pill strong {
		color: var(--accent-cyan, #58a6ff);
		font-weight: 700;
	}
	.stat-pill em {
		font-style: normal;
		color: var(--text-muted, #484f58);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.hero-links {
		display: flex;
		gap: 0.5rem;
	}
	.btn { text-decoration: none; transition: all 0.2s; font-weight: 600; border-radius: 6px; }
	.btn-sm { font-size: 0.78rem; padding: 0.35rem 0.8rem; }
	.btn-primary { background: var(--accent-cyan, #58a6ff); color: #0d1117; }
	.btn-primary:hover { background: #79c0ff; }
	.btn-ghost {
		color: var(--text-secondary, #8b949e);
		border: 1px solid var(--border, #30363d);
		background: transparent;
	}
	.btn-ghost:hover { border-color: var(--accent-cyan, #58a6ff); color: var(--text-primary, #e6edf3); }

	/* ═══ Sections ═══ */
	.section { margin: 2.5rem 0; }
	.section-header { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.25rem; }
	.section-header h2 { font-size: 1.35rem; margin: 0; border: none; padding: 0; }
	.section-badge {
		font-size: 0.68rem; padding: 0.2rem 0.55rem;
		background: rgba(88,166,255,0.1); color: var(--accent-cyan, #58a6ff);
		border-radius: 10px; font-weight: 600;
	}
	.live-badge {
		background: rgba(63,185,80,0.12);
		color: var(--accent-green, #3fb950);
		animation: pulse-badge 2s ease-in-out infinite;
	}
	@keyframes pulse-badge {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.65; }
	}

	/* ═══ Brief Cards — primary content ═══ */
	.brief-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
	.brief-card {
		display: flex;
		flex-direction: column;
		background: var(--bg-surface, #161b22);
		border: 1px solid var(--border, #30363d);
		border-radius: 10px;
		padding: 1.1rem 1.2rem;
		text-decoration: none;
		transition: all 0.25s;
		position: relative;
		overflow: hidden;
	}
	.brief-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, var(--accent-cyan, #58a6ff), var(--accent-green, #3fb950));
		opacity: 0;
		transition: opacity 0.25s;
	}
	.brief-card:hover::before { opacity: 1; }
	.brief-card:hover {
		border-color: var(--accent-cyan, #58a6ff);
		box-shadow: 0 0 20px rgba(88,166,255,0.08);
		transform: translateY(-2px);
	}
	.brief-card-empty {
		opacity: 0.4;
		pointer-events: none;
	}
	.brief-card-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.6rem;
	}
	.brief-icon { font-size: 1.1rem; }
	.brief-type {
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--accent-cyan, #58a6ff);
	}
	.brief-date {
		margin-left: auto;
		font-size: 0.72rem;
		color: var(--text-muted, #484f58);
	}
	.brief-card h3 {
		font-size: 0.95rem;
		margin: 0 0 0.4rem;
		color: var(--text-primary, #e6edf3);
		line-height: 1.3;
	}
	.brief-desc {
		font-size: 0.82rem;
		color: var(--text-secondary, #8b949e);
		margin: 0;
		line-height: 1.5;
		flex: 1;
	}
	.brief-cta {
		display: inline-block;
		margin-top: 0.8rem;
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--accent-cyan, #58a6ff);
		transition: transform 0.2s;
	}
	.brief-card:hover .brief-cta { transform: translateX(3px); }

	/* ═══ Brief Archive ═══ */
	.archive-list { display: flex; flex-direction: column; gap: 0.4rem; }
	.archive-row {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.5rem 0.75rem;
		border-radius: 8px;
		transition: background 0.2s;
	}
	.archive-row:hover { background: var(--bg-surface, #161b22); }
	.archive-date {
		font-family: var(--font-mono, 'JetBrains Mono', monospace);
		font-size: 0.82rem;
		color: var(--text-muted, #484f58);
		min-width: 100px;
	}
	.archive-links { display: flex; gap: 0.4rem; flex-wrap: wrap; }
	.archive-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.2rem 0.55rem;
		border-radius: 6px;
		font-size: 0.72rem;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.2s;
		border: 1px solid transparent;
	}
	.tag-morning {
		background: rgba(88,166,255,0.1);
		color: var(--accent-cyan, #58a6ff);
	}
	.tag-morning:hover { border-color: var(--accent-cyan, #58a6ff); }
	.tag-editor {
		background: rgba(210,153,34,0.1);
		color: var(--accent-gold, #d29922);
	}
	.tag-editor:hover { border-color: var(--accent-gold, #d29922); }
	.tag-mailbox {
		background: rgba(63,185,80,0.1);
		color: var(--accent-green, #3fb950);
	}
	.tag-mailbox:hover { border-color: var(--accent-green, #3fb950); }

	/* ═══ Article Grid ═══ */
	.article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
	.article-card {
		display: block;
		background: var(--bg-surface, #161b22);
		border: 1px solid var(--border, #30363d);
		border-radius: 10px;
		padding: 1.1rem;
		text-decoration: none;
		transition: all 0.25s;
	}
	.article-card:hover { border-color: var(--accent-cyan, #58a6ff); box-shadow: 0 0 15px rgba(88,166,255,0.06); transform: translateY(-2px); }
	.research-card { border-left: 3px solid var(--accent-gold, #d29922); }
	.card-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; font-size: 0.75rem; color: var(--text-muted, #484f58); }
	.lang-badge { padding: 0.1rem 0.35rem; border-radius: 4px; font-weight: 600; font-size: 0.62rem; }
	.lang-badge.en { background: rgba(88,166,255,0.15); color: var(--accent-cyan, #58a6ff); }
	.lang-badge.zh { background: rgba(248,81,73,0.15); color: var(--accent-red, #f85149); }
	.article-card h3 { font-size: 0.95rem; margin: 0 0 0.35rem; color: var(--text-primary, #e6edf3); line-height: 1.35; }
	.article-card p { font-size: 0.82rem; color: var(--text-secondary, #8b949e); margin: 0; line-height: 1.5; }

	/* ═══ Series ═══ */
	.series-list { display: flex; flex-direction: column; gap: 0.4rem; }
	.series-item {
		display: flex; align-items: center; gap: 1rem;
