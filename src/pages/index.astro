---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { readSiteData } from '../lib/investor-generated.js';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Brief posts (Morning Brief, Editor, Mailbox)
const briefEn = posts.filter(p => p.data.category === 'brief' && p.data.lang === 'en');
const briefZh = posts.filter(p => p.data.category === 'brief' && p.data.lang === 'zh');

// Classify brief types by slug prefix
const classifyBrief = (id: string) => {
	if (id.includes('editor-daily')) return 'editor';
	if (id.includes('mailbox-digest')) return 'mailbox';
	return 'morning';
};

const briefTypes = [
	{ key: 'morning', icon: '01', en: 'Morning Brief', zh: '晨间简报', desc_en: '7-stage analyst pipeline', desc_zh: '7阶段分析师管线' },
	{ key: 'editor', icon: '02', en: 'Editor Report', zh: '总编报告', desc_en: '4-phase contradiction sweep', desc_zh: '4阶段矛盾梳理' },
	{ key: 'mailbox', icon: '03', en: 'Mailbox Digest', zh: '邮箱摘要', desc_en: 'Cross-desk exchanges', desc_zh: '跨部门交流' },
];

// Get latest brief of each type
const latestBriefsEn = briefTypes.map(t => ({
	...t,
	post: briefEn.find(p => classifyBrief(p.id) === t.key) || null,
}));
const latestBriefsZh = briefTypes.map(t => ({
	...t,
	post: briefZh.find(p => classifyBrief(p.id) === t.key) || null,
}));

// Group remaining content
const instituteEn = posts.filter(p => p.data.category === 'institute' && p.data.lang === 'en');
const instituteZh = posts.filter(p => p.data.category === 'institute' && p.data.lang === 'zh');
const researchEn = posts.filter(p => p.data.category === 'research' && p.data.lang === 'en');
const researchZh = posts.filter(p => p.data.category === 'research' && p.data.lang === 'zh');
const vibelogEn = posts.filter(p => p.data.category === 'vibelog' && p.data.lang === 'en');
const vibelogZh = posts.filter(p => p.data.category === 'vibelog' && p.data.lang === 'zh');

// Brief archive (all briefs, grouped by date)
const briefDatesEn = new Map<string, typeof briefEn>();
briefEn.forEach(p => {
	const date = p.data.pubDate.toISOString().split('T')[0];
	if (!briefDatesEn.has(date)) briefDatesEn.set(date, []);
	briefDatesEn.get(date)!.push(p);
});
const briefDatesZh = new Map<string, typeof briefZh>();
briefZh.forEach(p => {
	const date = p.data.pubDate.toISOString().split('T')[0];
	if (!briefDatesZh.has(date)) briefDatesZh.set(date, []);
	briefDatesZh.get(date)!.push(p);
});

const investorData = readSiteData();
const dailyBrief = investorData.dailyBrief || {};
const dailySynthesis = dailyBrief.synthesis || {};
const dailyStats = dailyBrief.stats || {};
const dailyBullets = Array.isArray(dailySynthesis.bullets) ? dailySynthesis.bullets.slice(0, 3) : [];
const dailyWatchItems = Array.isArray(dailySynthesis.watchItems) ? dailySynthesis.watchItems.slice(0, 3) : [];
const mapCoordinates: Record<string, [number, number]> = {
	'宏观通胀传导': [39.5, -98.35],
	'AI 基础设施': [37.34, -121.89],
	'工业供给瓶颈': [31.23, 121.47],
	'电力与电网': [52.52, 13.4],
	'半导体与存储': [24.8, 120.99],
	'消费与生产率': [35.68, 139.76],
};
const fallbackCoordinates: [number, number][] = [[51.5, -0.1], [1.35, 103.82], [19.07, 72.88], [-33.86, 151.21]];
const signalAccents = ['#2f80ed', '#169b62', '#d64545', '#d7a316', '#e46f2e'];
const dailyMapItems = (dailyBrief.chainRadar || []).slice(0, 6).map((item, index) => ({
	label: item.label,
	heat: item.heat,
	latest: item.latest,
	recent: item.recent,
	risk: item.risk,
	href: item.evidence?.[0]?.href || '/investor/#dailyReports',
	evidenceTitle: item.evidence?.[0]?.title || '',
	coords: mapCoordinates[item.label] || fallbackCoordinates[index % fallbackCoordinates.length],
	accent: signalAccents[index % signalAccents.length],
}));
const serializedHomeSignalMap = JSON.stringify(dailyMapItems).replaceAll('<', '\\u003c');
const parseMarketLine = (line: string) => {
	const text = String(line || '').replace(/\s+/g, ' ').trim();
	const match = text.match(/^(.+?)\s+([~]?[0-9][0-9,]*(?:\.[0-9]+)?(?:\s*(?:USD\/bbl|USD\/oz|%))?)(?:\s+\((.*)\))?$/);
	const change = match?.[3] || '';
	return {
		label: match?.[1] || text,
		value: match?.[2] || '',
		change,
		direction: change.includes('-') ? 'down' : change ? 'up' : 'flat',
	};
};
const marketTickerRows = (dailyBrief.marketTape?.zh || []).slice(0, 8).map(parseMarketLine);
const marketTapeRows = (dailyBrief.marketTape?.zh || []).slice(0, 10).map(parseMarketLine);
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<!-- Bloomberg-style Market Ticker Banner -->
		<div class="market-ticker-banner">
			<div class="ticker-wrapper">
				<div class="ticker-track">
					{[...marketTickerRows, ...marketTickerRows].map((row) => (
						<a class="ticker-item" href="/investor/#dailyReports">
							<span class="ticker-label">{row.label}</span>
							<span class="ticker-val">{row.value}</span>
							<span class={`ticker-change ${row.direction}`}>{row.change || 'latest'}</span>
						</a>
					))}
				</div>
			</div>
		</div>
		<main>
			<!-- Compact Hero Banner -->
			<section class="hero-banner">
				<div class="hero-inner">
					<div class="hero-left">
						<h1>Research<span class="accent">OS</span></h1>
						<p class="hero-tagline" data-en="Multi-agent autonomous research · 42 AI analysts · Daily briefs" data-zh="多智能体自主研究 · 42位AI分析师 · 每日简报">
							Multi-agent autonomous research · 42 AI analysts · Daily briefs
						</p>
					</div>
					<div class="hero-right">
						<div class="hero-stats-inline">
							<span class="stat-pill"><strong>42</strong> <em data-en="analysts" data-zh="分析师">analysts</em></span>
							<span class="stat-pill"><strong>1,062+</strong> <em data-en="reports" data-zh="报告">reports</em></span>
							<span class="stat-pill"><strong>50+</strong> <em data-en="sessions" data-zh="研讨">sessions</em></span>
						</div>
						<div class="hero-links">
							<a href="/blog" class="btn btn-sm btn-primary" data-en="All Articles" data-zh="全部文章">All Articles</a>
							<a href="https://github.com/dmquant/vibe" class="btn btn-sm btn-ghost" target="_blank">GitHub →</a>
						</div>
					</div>
				</div>
			</section>

			<section class="home-signal-board" id="daily-dashboard">
				<div class="signal-board-top">
					<div>
						<div class="signal-eyebrow" data-en="Daily Signal Dashboard" data-zh="每日信号看板">Daily Signal Dashboard</div>
						<h2 data-en="Morning brief, market tape, and research-chain map" data-zh="晨会简报、市场报价与研究链地图">Morning brief, market tape, and research-chain map</h2>
						<p>{dailySynthesis.headline || '今日研究信号已同步。'}</p>
					</div>
					<div class="signal-actions">
						<a href="/investor/#daily" class="btn btn-sm btn-primary" data-en="Open full dashboard" data-zh="打开完整看板">Open full dashboard</a>
						<a href={dailyBrief.docxHref || '/investor/#dailyReports'} class="btn btn-sm btn-ghost" data-en="Download brief" data-zh="下载简报">Download brief</a>
					</div>
				</div>
				<div class="signal-stat-strip">
					<a href="/investor/#dailyReports"><span data-en="Reports" data-zh="报告">Reports</span><strong>{dailyStats.reports || 0}</strong></a>
					<a href="/investor/#dailyHeatmap"><span data-en="Analysts" data-zh="分析师">Analysts</span><strong>{dailyStats.analysts || 0}</strong></a>
					<a href="/investor/#dailyChains"><span data-en="Chains" data-zh="链条">Chains</span><strong>{dailyStats.activeChains || 0}</strong></a>
					<a href="/investor/#dailyRisks"><span data-en="Risks" data-zh="风险">Risks</span><strong>{dailyStats.riskItems || 0}</strong></a>
				</div>
				<div class="signal-board-grid">
					<article class="signal-panel signal-main-panel">
						<div class="signal-panel-title" data-en="Priority conclusions" data-zh="优先结论">Priority conclusions</div>
						<a class="signal-lead" href={dailyBullets[0]?.href || '/investor/#dailyReports'}>
							<strong>{dailySynthesis.headline || '今日研究信号'}</strong>
							<span>{dailySynthesis.lead || '简报优先呈现可追溯的结论、变化、风险和证据入口。'}</span>
						</a>
						<div class="signal-bullet-list">
							{dailyBullets.map((item, index) => (
								<a href={item.href || '/investor/#dailyReports'} class="signal-bullet" style={`--accent:${signalAccents[index % signalAccents.length]}`}>
									<span>{item.label || `Signal ${index + 1}`}</span>
									<strong>{item.text || ''}</strong>
								</a>
							))}
						</div>
					</article>
					<article class="signal-panel signal-map-panel">
						<div class="signal-panel-title" data-en="Global research-chain map" data-zh="全球研究链地图">Global research-chain map</div>
						<div id="homeSignalMap" class="home-signal-map" aria-label="Research-chain map"></div>
						<div class="signal-map-tags">
							{dailyMapItems.map((item, index) => (
								<a href={item.href} style={`--accent:${signalAccents[index % signalAccents.length]}`}>{item.label}</a>
							))}
						</div>
					</article>
					<article class="signal-panel signal-tape-panel">
						<div class="signal-panel-title" data-en="Latest prices" data-zh="最新报价">Latest prices</div>
						<div class="signal-market-list">
							{marketTapeRows.map((row) => (
								<a href="/investor/#dailyReports" class={`signal-market-row ${row.direction}`}>
									<span>{row.label}</span>
									<strong>{row.value}</strong>
									<em>{row.change || 'latest'}</em>
								</a>
							))}
						</div>
						{dailyWatchItems.length ? (
							<div class="signal-watch-list">
								{dailyWatchItems.map((item) => (
									<a href={item.href || '/investor/#dailyReports'}>
										<strong>{item.title}</strong>
										<span>{item.reason}</span>
									</a>
								))}
							</div>
						) : null}
					</article>
				</div>
			</section>

			<!-- ═══════════════════════════════════════════════════════════ -->
			<!-- Latest Daily Briefs — the primary content                 -->
			<!-- ═══════════════════════════════════════════════════════════ -->
			<section class="section briefs-section">
				<div class="section-header">
					<h2 data-en="Latest Daily Briefs" data-zh="最新每日简报">Latest Daily Briefs</h2>
					<span class="section-badge live-badge" data-en="Auto-generated" data-zh="自动生成">Auto-generated</span>
				</div>

				<!-- EN Briefs -->
				<div class="brief-grid lang-content" data-show-lang="en">
					{latestBriefsEn.map(({ icon, en, desc_en, post }) => (
						post ? (
							<a href={`/blog/${post.id}/`} class="brief-card">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{en}</span>
									<span class="brief-date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
								<h3>{post.data.private ? 'Classified Intelligence' : post.data.title}</h3>
								<p class="brief-desc">{post.data.private ? 'This report is encrypted to prevent public data leakage. Enter authorized decryption key inside the article to proceed.' : post.data.description}</p>
								<span class="brief-cta">Read full report →</span>
							</a>
						) : (
							<div class="brief-card brief-card-empty">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{en}</span>
								</div>
								<p class="brief-desc">{desc_en} — coming soon</p>
							</div>
						)
					))}
				</div>

				<!-- ZH Briefs -->
				<div class="brief-grid lang-content" data-show-lang="zh">
					{latestBriefsZh.map(({ icon, zh, desc_zh, post }) => (
						post ? (
							<a href={`/blog/${post.id}/`} class="brief-card">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{zh}</span>
									<span class="brief-date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
								<h3>{post.data.private ? '机密情报审查' : post.data.title}</h3>
								<p class="brief-desc">{post.data.private ? '此报告已加密以防止公开数据泄露。请输入授权解密密钥以继续。' : post.data.description}</p>
								<span class="brief-cta">阅读完整报告 →</span>
							</a>
						) : (
							<div class="brief-card brief-card-empty">
								<div class="brief-card-header">
									<span class="brief-icon">{icon}</span>
									<span class="brief-type">{zh}</span>
								</div>
								<p class="brief-desc">{desc_zh} — 即将推出</p>
							</div>
						)
					))}
				</div>
			</section>

			<!-- Brief Archive -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="Brief Archive" data-zh="简报存档">Brief Archive</h2>
				</div>

				<div class="archive-list lang-content" data-show-lang="en">
					{[...briefDatesEn.entries()].slice(0, 7).map(([date, datePosts]) => (
						<div class="archive-row">
							<span class="archive-date">{date}</span>
							<div class="archive-links">
								{datePosts.map(p => {
									const type = classifyBrief(p.id);
									const typeInfo = briefTypes.find(t => t.key === type);
									return (
										<a href={`/blog/${p.id}/`} class={`archive-tag tag-${type}`}>
											{typeInfo?.icon} {typeInfo?.en}
										</a>
									);
								})}
							</div>
						</div>
					))}
				</div>

				<div class="archive-list lang-content" data-show-lang="zh">
					{[...briefDatesZh.entries()].slice(0, 7).map(([date, datePosts]) => (
						<div class="archive-row">
							<span class="archive-date">{date}</span>
							<div class="archive-links">
								{datePosts.map(p => {
									const type = classifyBrief(p.id);
									const typeInfo = briefTypes.find(t => t.key === type);
									return (
										<a href={`/blog/${p.id}/`} class={`archive-tag tag-${type}`}>
											{typeInfo?.icon} {typeInfo?.zh}
										</a>
									);
								})}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Deep Research Papers -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="Deep Research Papers" data-zh="深度研究论文">Deep Research Papers</h2>
					<span class="section-badge" data-en="Latest" data-zh="最新">Latest</span>
				</div>
				<div class="article-grid lang-content" data-show-lang="en">
					{researchEn.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card research-card">
							<div class="card-meta">
								<span class="lang-badge en">EN</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.private ? 'Classified Intelligence' : post.data.title}</h3>
							<p>{post.data.private ? 'This report is encrypted to prevent public data leakage. Enter authorized decryption key inside the article to proceed.' : post.data.description}</p>
						</a>
					))}
				</div>
				<div class="article-grid lang-content" data-show-lang="zh">
					{researchZh.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card research-card">
							<div class="card-meta">
								<span class="lang-badge zh">中文</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.private ? '机密情报审查' : post.data.title}</h3>
							<p>{post.data.private ? '此报告已加密以防止公开数据泄露。请输入授权解密密钥以继续。' : post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<!-- Institute Series -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="The Institute Series" data-zh="智研所系列">The Institute Series</h2>
					<span class="section-badge" data-en="6-Part Deep Dive" data-zh="6篇深度解析">6-Part Deep Dive</span>
				</div>
				<div class="series-list lang-content" data-show-lang="en">
					{instituteEn.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="series-item">
							<span class="series-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="series-content">
								<h4>{post.data.private ? 'Classified Intelligence' : post.data.title}</h4>
								<p>{post.data.private ? 'This report is encrypted to prevent public data leakage. Enter authorized decryption key inside the article to proceed.' : post.data.description}</p>
							</div>
							<span class="series-arrow">→</span>
						</a>
					))}
				</div>
				<div class="series-list lang-content" data-show-lang="zh">
					{instituteZh.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="series-item">
							<span class="series-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="series-content">
								<h4>{post.data.private ? '机密情报审查' : post.data.title}</h4>
								<p>{post.data.private ? '此报告已加密以防止公开数据泄露。请输入授权解密密钥以继续。' : post.data.description}</p>
							</div>
							<span class="series-arrow">→</span>
						</a>
					))}
				</div>
			</section>

			<!-- Vibelog & Guides -->
			<section class="section">
				<div class="section-header">
					<h2 data-en="Vibelog & Guides" data-zh="指南与文档">Vibelog & Guides</h2>
				</div>
				<div class="article-grid lang-content" data-show-lang="en">
					{vibelogEn.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card">
							<div class="card-meta">
								<span class="lang-badge en">EN</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.private ? 'Classified Intelligence' : post.data.title}</h3>
							<p>{post.data.private ? 'This report is encrypted to prevent public data leakage. Enter authorized decryption key inside the article to proceed.' : post.data.description}</p>
						</a>
					))}
				</div>
				<div class="article-grid lang-content" data-show-lang="zh">
					{vibelogZh.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card">
							<div class="card-meta">
								<span class="lang-badge zh">中文</span>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3>{post.data.private ? '机密情报审查' : post.data.title}</h3>
							<p>{post.data.private ? '此报告已加密以防止公开数据泄露。请输入授权解密密钥以继续。' : post.data.description}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />

		<script id="home-signal-map-data" type="application/json" is:inline set:html={serializedHomeSignalMap}></script>
		<script>
			import "../scripts/home-signal-map.js";
		</script>
		<script>
			function applyLang(lang: string) {
				document.querySelectorAll('.lang-content').forEach(el => {
					const showLang = (el as HTMLElement).dataset.showLang;
					(el as HTMLElement).style.display = showLang === lang ? '' : 'none';
				});
				document.querySelectorAll('[data-en][data-zh]').forEach(el => {
					const htmlEl = el as HTMLElement;
					const text = lang === 'zh' ? htmlEl.dataset.zh : htmlEl.dataset.en;
					if (text) htmlEl.textContent = text;
				});
			}
			const initialLang = localStorage.getItem('researchos-lang') || 'en';
			applyLang(initialLang);
			window.addEventListener('lang-change', (e: Event) => {
				const detail = (e as CustomEvent).detail;
				applyLang(detail.lang);
			});
		</script>
	</body>
</html>

<style>
	/* ═══ Compact Hero Banner ═══ */
	.hero-banner {
		border-bottom: 1px solid var(--border, #30363d);
		background:
			linear-gradient(var(--grid-faint) 1px, transparent 1px),
			linear-gradient(90deg, var(--grid-faint) 1px, transparent 1px),
			var(--bg-primary);
		background-size: 28px 28px;
		padding: 1.5rem 1rem;
	}
	.hero-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}
	.hero-left h1 {
		font-size: 2.2rem;
		font-weight: 800;
		margin: 0 0 0.25rem;
		letter-spacing: -0.02em;
	}
	.accent { color: var(--accent-blue, #2f80ed); }
	.hero-tagline {
		color: var(--text-secondary, #8b949e);
		font-size: 0.88rem;
		margin: 0;
	}
	.hero-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.75rem;
	}
	.hero-stats-inline {
		display: flex;
		gap: 0.6rem;
