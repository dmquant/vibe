---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	counterpartUrl?: string | null;
};

const { title, description, pubDate, updatedDate, heroImage, lang, category, counterpartUrl, private: isPrivate = false } = Astro.props;

const categoryLabels: Record<string, { en: string; zh: string }> = {
	brief: { en: 'Daily Brief', zh: '每日简报' },
	research: { en: 'Deep Research', zh: '深度研究' },
	institute: { en: 'Institute Series', zh: '智研所系列' },
	vibelog: { en: 'Vibelog & Guides', zh: '指南与文档' },
};
const catLabel = categoryLabels[category || 'vibelog'] || categoryLabels.vibelog;

let encryptedContent = '';
if (isPrivate) {
	try {
		const crypto = await import('node:crypto');
		const rawHtml = await Astro.slots.render('default');
		const password = process.env.DECRYPT_PASSWORD || 'quant2026';
		const key = crypto.createHash('sha256').update(password).digest();
		const iv = crypto.randomBytes(16);
		const cipher = crypto.createCipheriv('aes-256-cbc', key, iv);
		// Package title, description, and html payload to prevent metadata leaks in public builds
		const payload = JSON.stringify({
			title,
			description,
			html: rawHtml
		});
		let encrypted = cipher.update(payload, 'utf8', 'base64');
		encrypted += cipher.final('base64');
		encryptedContent = iv.toString('base64') + ':' + encrypted;
	} catch (e) {
		console.error('Error encrypting page:', e);
	}
}

// Compute display values to mask sensitive strategic keywords from search crawlers
const displayTitle = isPrivate 
	? (lang === 'zh' ? '🔒 机密情报审查' : '🔒 Classified Intelligence') 
	: title;

const displayDesc = isPrivate 
	? (lang === 'zh' 
		? '此报告已加密以防止公开数据泄露。请输入授权解密密钥以继续。' 
		: 'This report is encrypted to prevent public data leakage. Enter authorized decryption key inside the article to proceed.') 
	: description;
---

<html lang={lang || 'en'} data-lang={lang || 'en'}>
	<head>
		<BaseHead title={displayTitle} description={displayDesc} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.article-header {
				max-width: 780px;
				margin: 2rem auto 0;
				padding: 0 1rem;
			}
			.breadcrumb {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-size: 0.8rem;
				color: var(--text-muted, #484f58);
				margin-bottom: 1.5rem;
			}
			.breadcrumb a {
				color: var(--text-secondary, #8b949e);
				text-decoration: none;
			}
			.breadcrumb a:hover { color: var(--accent-cyan, #58a6ff); }
			.breadcrumb .sep { color: var(--text-muted, #484f58); }

			.article-meta {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				margin-bottom: 1rem;
				flex-wrap: wrap;
			}
			.cat-badge {
				padding: 0.2rem 0.6rem;
				border-radius: 6px;
				font-size: 0.7rem;
				font-weight: 600;
				background: rgba(88,166,255,0.1);
				color: var(--accent-cyan, #58a6ff);
			}
			.lang-indicator {
				padding: 0.15rem 0.4rem;
				border-radius: 4px;
				font-weight: 600;
				font-size: 0.65rem;
			}
			.lang-indicator.en { background: rgba(88,166,255,0.15); color: var(--accent-cyan, #58a6ff); }
			.lang-indicator.zh { background: rgba(248,81,73,0.15); color: var(--accent-red, #f85149); }
			.date-text {
				color: var(--text-muted, #484f58);
				font-size: 0.82rem;
			}
			.counterpart-link {
				margin-left: auto;
				font-size: 0.78rem;
				padding: 0.25rem 0.6rem;
				border: 1px solid var(--border, #30363d);
				border-radius: 6px;
				color: var(--text-secondary, #8b949e);
				text-decoration: none;
				transition: all 0.2s;
			}
			.counterpart-link:hover {
				border-color: var(--accent-cyan, #58a6ff);
				color: var(--accent-cyan, #58a6ff);
			}

			.article-title {
				font-size: 2.2rem;
				font-weight: 800;
				line-height: 1.2;
				margin: 0 0 1.5rem;
				color: var(--text-primary, #e6edf3);
			}
			.title-divider {
				border: none;
				border-top: 1px solid var(--border, #30363d);
				margin: 0 0 2rem;
			}

			.prose {
				max-width: 780px;
				margin: 0 auto;
				padding: 0 1rem 3rem;
				font-family: var(--font-serif, 'Source Serif 4', Georgia, serif);
				font-size: 1.05rem;
				line-height: 1.85;
				color: var(--text-primary, #e6edf3);
			}
			.prose :global(h1),
			.prose :global(h2),
			.prose :global(h3) {
				font-family: var(--font-ui, 'Inter', sans-serif);
			}
			.prose :global(p) { margin-bottom: 1.5em; }
			.prose :global(img) {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
				border: 1px solid var(--border, #30363d);
				margin: 1.5rem 0;
			}
			.last-updated {
				font-style: italic;
				color: var(--text-muted, #484f58);
				font-size: 0.82rem;
			}

			/* Mermaid diagram containers */
			.prose :global(.mermaid-container) {
				margin: 1.5rem 0;
				padding: 1.5rem;
				background: #0d1117;
				border: 1px solid var(--border, #30363d);
				border-radius: 8px;
				overflow-x: auto;
				text-align: center;
			}
			.prose :global(.mermaid-container svg) {
				max-width: 100%;
				height: auto;
			}
			.prose :global(pre.mermaid-error) {
				border-color: var(--accent-red, #f85149) !important;
				opacity: 0.7;
			}

			/* Lock Screen Styling */
			.lock-screen-wrapper {
				display: flex;
				justify-content: center;
				align-items: center;
				padding: 3rem 1rem;
				min-height: 440px;
				position: relative;
				overflow: hidden;
				border-radius: 12px;
				background: #030712;
				border: 1px solid rgba(0, 230, 118, 0.15);
			}
			.lock-screen-wrapper::before {
				content: " ";
				display: block;
				position: absolute;
				top: 0; left: 0; bottom: 0; right: 0;
				background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(0, 230, 118, 0.03), rgba(0, 176, 255, 0.02), rgba(0, 230, 118, 0.03));
				z-index: 2;
				background-size: 100% 3px, 6px 100%;
				pointer-events: none;
			}
			.lock-screen-wrapper::after {
				content: '';
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
				background: radial-gradient(circle, transparent 40%, rgba(3, 7, 18, 0.8) 100%);
				pointer-events: none;
				z-index: 2;
			}
			.matrix-bg {
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
				opacity: 0.15;
				pointer-events: none;
				z-index: 1;
				overflow: hidden;
				user-select: none;
			}
			.matrix-bg canvas {
				display: block;
				width: 100%;
				height: 100%;
			}
			.lock-card {
				background: rgba(10, 15, 30, 0.85);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border: 1px solid #00e676;
				border-radius: 8px;
				padding: 2.5rem;
				max-width: 480px;
				width: 100%;
				text-align: center;
				box-shadow: 0 0 30px rgba(0, 230, 118, 0.15), inset 0 0 15px rgba(0, 230, 118, 0.05);
				transition: all 0.3s ease;
				z-index: 3;
				position: relative;
			}
			.lock-card::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0; height: 3px;
				background: linear-gradient(90deg, #00e676, #00b0ff);
				border-radius: 8px 8px 0 0;
			}
			.lock-card:hover {
				border-color: #00b0ff;
				box-shadow: 0 0 40px rgba(0, 176, 255, 0.25), inset 0 0 20px rgba(0, 176, 255, 0.1);
			}
			.lock-icon {
				font-size: 3rem;
				margin-bottom: 1.2rem;
				animation: pulse-glow 2.5s infinite ease-in-out;
			}
			@keyframes pulse-glow {
				0%, 100% { transform: scale(1); filter: drop-shadow(0 0 5px rgba(0, 230, 118, 0.4)); }
				50% { transform: scale(1.06); filter: drop-shadow(0 0 20px rgba(0, 230, 118, 0.8)); }
			}
			.lock-title {
				font-size: 1.2rem;
				font-weight: 800;
				margin: 0 0 1rem;
				letter-spacing: 2px;
				color: #ffffff;
				text-shadow: 0 0 8px rgba(0, 230, 118, 0.4);
				font-family: var(--font-mono, monospace);
				text-transform: uppercase;
			}
			.lock-desc {
				font-size: 0.82rem;
				color: #8b949e;
				line-height: 1.6;
				margin-bottom: 1.5rem;
				text-align: left;
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(0, 230, 118, 0.1);
				padding: 12px 16px;
				border-radius: 6px;
				font-family: var(--font-mono, monospace);
			}
			.terminal-prompt {
				color: #00e676;
				margin-right: 6px;
				font-weight: bold;
				animation: blink 1s infinite steps(1);
			}
			@keyframes blink {
				0%, 100% { opacity: 1; }
				50% { opacity: 0; }
			}
			.input-group-cyber {
				display: flex;
				gap: 8px;
				margin-bottom: 1rem;
				align-items: center;
			}
			.input-group-cyber input[type="password"] {
				flex: 1;
				background: rgba(0, 0, 0, 0.6);
				color: #00e676;
				border: 1px solid rgba(0, 230, 118, 0.25);
				border-radius: 4px;
				padding: 10px 16px;
				font-size: 0.95rem;
				outline: none;
				transition: all 0.2s ease;
				font-family: var(--font-mono, monospace);
				letter-spacing: 3px;
			}
			.input-group-cyber input[type="password"]:focus {
				border-color: #00e676;
				box-shadow: 0 0 10px rgba(0, 230, 118, 0.3);
			}
			.input-group-cyber input.input-error {
				border-color: #f85149;
				color: #f85149;
				animation: shake 0.3s ease;
			}
			@keyframes shake {
				0%, 100% { transform: translateX(0); }
				25% { transform: translateX(-6px); }
				75% { transform: translateX(6px); }
			}
			.btn-cyber {
				background: transparent;
				color: #00e676;
				border: 1px solid #00e676;
				border-radius: 4px;
				padding: 10px 20px;
				font-size: 0.85rem;
				font-weight: bold;
				cursor: pointer;
				transition: all 0.2s ease;
				letter-spacing: 1px;
				font-family: var(--font-mono, monospace);
			}
			.btn-cyber:hover {
				background: rgba(0, 230, 118, 0.1);
				box-shadow: 0 0 15px rgba(0, 230, 118, 0.3);
			}
			.error-msg {
				color: #f85149;
				font-size: 0.8rem;
				font-weight: bold;
				margin-top: 0.5rem;
				font-family: var(--font-mono, monospace);
				text-align: left;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="article-header">
					<nav class="breadcrumb">
						<a href="/" data-en="Home" data-zh="首页">Home</a>
						<span class="sep">›</span>
						<a href="/blog" data-en="Articles" data-zh="文章">Articles</a>
						<span class="sep">›</span>
						<span data-en={catLabel.en} data-zh={catLabel.zh}>{lang === 'zh' ? catLabel.zh : catLabel.en}</span>
					</nav>
					<div class="article-meta">
						<span class={`lang-indicator ${lang || 'en'}`}>{lang === 'zh' ? '中文' : 'EN'}</span>
						<span class="cat-badge">{lang === 'zh' ? catLabel.zh : catLabel.en}</span>
						<span class="date-text"><FormattedDate date={pubDate} /></span>
						{updatedDate && (
							<span class="last-updated">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
						{counterpartUrl && (
							<a href={counterpartUrl} class="counterpart-link" id="counterpart-link" data-url={counterpartUrl}>
								{lang === 'zh' ? '🇺🇸 Read in English' : '🇨🇳 阅读中文版'}
							</a>
						)}
					</div>
					<h1 class="article-title" id="article-main-title">{displayTitle}</h1>
					<hr class="title-divider" />
				</div>
				<div class="prose">
					{isPrivate ? (
						<div id="encrypted-container" data-ciphertext={encryptedContent}>
							<div class="lock-screen-wrapper">
								<div class="matrix-bg" id="matrix-rain"></div>
								<div class="lock-card">
									<div class="lock-icon">🔒</div>
									<h2 class="lock-title">
										{lang === 'zh' ? 'SECURE COGNITIVE GATEWAY' : 'SECURE COGNITIVE GATEWAY'}
									</h2>
									<div class="lock-desc">
										<div><span style="color:#00b0ff;">[SECURE_SHELL]:</span> ACTIVE</div>
										<div><span style="color:#00e676;">[PERIMETER]:</span> SAFE-GATED</div>
										<div style="margin-top: 8px;">{lang === 'zh' 
											? '此报告属于AI研究所机密研究。请输入授权解密密钥以加载数据流。' 
											: 'Classified multi-agent research payload. Enter cryptographic key to resolve data-stream.'}</div>
									</div>
									<div class="input-group-cyber">
										<span class="terminal-prompt" style="font-family: monospace; font-size:1.1rem;">&gt;</span>
										<input type="password" id="decrypt-password" placeholder={lang === 'zh' ? 'PASSCODE_CREDENTIAL' : 'PASSCODE_CREDENTIAL'} />
										<button id="btn-decrypt" class="btn-cyber">
											{lang === 'zh' ? 'UNLOCK' : 'UNLOCK'}
										</button>
									</div>
									<div id="decrypt-error" class="error-msg" style="display:none;"></div>
								</div>
							</div>
						</div>
						
						<div id="decrypted-content" style="display:none;"></div>
					) : (
						<slot />
					)}
				</div>
			</article>
		</main>
		<Footer />

		{counterpartUrl && (
			<script define:vars={{ counterpartUrl, lang }}>
				// When the header language toggle is clicked on an article page,
				// navigate to the counterpart article instead of just toggling text
				window.addEventListener('lang-change', (e) => {
					const newLang = e.detail.lang;
					const currentLang = lang || 'en';
					if (newLang !== currentLang && counterpartUrl) {
						window.location.href = counterpartUrl;
					}
				});
			</script>
		)}

		<!-- Mermaid.js: render ```mermaid code blocks as diagrams -->
		<script>
			async function initMermaid() {
				const codeBlocks = document.querySelectorAll('code.language-mermaid');
				if (codeBlocks.length === 0) return;

				// Dynamic import from CDN
				const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

				mermaid.initialize({
					startOnLoad: false,
					theme: 'dark',
					themeVariables: {
						darkMode: true,
						background: '#161b22',
						primaryColor: '#1f6feb',
						primaryTextColor: '#e6edf3',
						primaryBorderColor: '#30363d',
						lineColor: '#8b949e',
						secondaryColor: '#21262d',
						tertiaryColor: '#161b22',
						fontFamily: 'Inter, sans-serif',
						fontSize: '14px',
						nodeTextColor: '#e6edf3',
					},
					securityLevel: 'loose',
					fontFamily: 'Inter, sans-serif',
				});

				for (let i = 0; i < codeBlocks.length; i++) {
					const codeEl = codeBlocks[i];
					const preEl = codeEl.parentElement;
					if (!preEl || preEl.tagName !== 'PRE') continue;

					const graphText = codeEl.textContent?.trim() || '';
					if (!graphText) continue;

					try {
						const id = `mermaid-diagram-${i}`;
						const { svg } = await mermaid.render(id, graphText);

						const container = document.createElement('div');
						container.className = 'mermaid-container';
						container.innerHTML = svg;
						preEl.replaceWith(container);
					} catch (err) {
						console.warn(`Mermaid render failed for block ${i}:`, err);
						// Leave the code block as-is on error
						preEl.classList.add('mermaid-error');
					}
				}
			}

			// Bind globally for post-decryption rerun
			window.initMermaid = initMermaid;

			// Run after DOM is ready
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initMermaid);
			} else {
				initMermaid();
			}
		</script>

		<!-- CryptoJS Decryption -->
		{isPrivate && (
			<script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js" is:inline></script>
			<script is:inline>
				// Client-side decryption and UI animation script
				document.addEventListener('DOMContentLoaded', () => {
					const container = document.getElementById('encrypted-container');
					const decryptedContainer = document.getElementById('decrypted-content');
					const passwordInput = document.getElementById('decrypt-password');
					const btnDecrypt = document.getElementById('btn-decrypt');
					const errorMsg = document.getElementById('decrypt-error');
					
					if (!container || !decryptedContainer || !passwordInput || !btnDecrypt) return;
					
					// Matrix Digital Rain background animation
					const matrixEl = document.getElementById('matrix-rain');
					let intervalId = null;
					if (matrixEl) {
						const canvas = document.createElement('canvas');
						matrixEl.appendChild(canvas);
						const ctx = canvas.getContext('2d');
						let w = canvas.width = matrixEl.clientWidth;
						let h = canvas.height = matrixEl.clientHeight;
						
						const resizeCanvas = () => {
							if (!matrixEl.contains(canvas)) return;
							w = canvas.width = matrixEl.clientWidth;
							h = canvas.height = matrixEl.clientHeight;
						};
						window.addEventListener('resize', resizeCanvas);

						const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ$#@%&*+-/<>".split("");
						const fontSize = 10;
						const columns = Math.floor(w / fontSize) + 1;
						const ypos = Array(columns).fill(0);

						function matrix() {
							ctx.fillStyle = 'rgba(3, 7, 18, 0.05)';
							ctx.fillRect(0, 0, w, h);
							
							ctx.fillStyle = '#00e676';
							ctx.font = '8px monospace';
							
							ypos.forEach((y, index) => {
								const text = chars[Math.floor(Math.random() * chars.length)];
								const x = index * fontSize;
								ctx.fillText(text, x, y);
								
								if (y > 100 + Math.random() * 10000) {
									ypos[index] = 0;
								} else {
									ypos[index] = y + fontSize;
								}
							});
						}
						intervalId = setInterval(matrix, 40);
					}
					
					const ciphertextWithIv = container.getAttribute('data-ciphertext');
					
					function attemptDecryption() {
						const password = passwordInput.value.trim();
						if (!password) {
							showError("Please enter a key.");
							return;
						}
						
						try {
							const parts = ciphertextWithIv.split(':');
							if (parts.length !== 2) {
								showError("Invalid ciphertext format.");
								return;
							}
							
							const ivBase64 = parts[0];
							const encryptedBase64 = parts[1];
							
							// Derive key from password using SHA256 (matching Node side)
							const key = CryptoJS.SHA256(password);
							
							// Convert base64 IV to CryptoJS WordArray
							const iv = CryptoJS.enc.Base64.parse(ivBase64);
							
							// Decrypt
							const decrypted = CryptoJS.AES.decrypt(encryptedBase64, key, {
								iv: iv,
								mode: CryptoJS.mode.CBC,
								padding: CryptoJS.pad.Pkcs7
							});
							
							const plaintext = decrypted.toString(CryptoJS.enc.Utf8);
							
							if (!plaintext) {
								showError("Decryption failed. Incorrect key.");
								return;
							}
							
							// Parse package containing title, description, and html
							const payload = JSON.parse(plaintext);
							
							// Successful decryption! Stop Matrix Rain timer
							if (intervalId) {
								clearInterval(intervalId);
							}
							
							container.style.display = 'none';
							decryptedContainer.innerHTML = payload.html;
							decryptedContainer.style.display = 'block';
							
							// Dynamically update document title and H1 page title
							document.title = payload.title;
							const h1TitleEl = document.getElementById('article-main-title');
							if (h1TitleEl) {
								h1TitleEl.textContent = payload.title;
							}
							
							// Rerun Mermaid rendering after decryption
							if (window.initMermaid) {
								window.initMermaid();
							}
						} catch (err) {
							console.error("Decryption error:", err);
							showError("Decryption failed. Incorrect key.");
						}
					}
					
					function showError(msg) {
						if (errorMsg) {
							errorMsg.textContent = msg;
							errorMsg.style.display = 'block';
						}
						passwordInput.classList.add('input-error');
						setTimeout(() => passwordInput.classList.remove('input-error'), 500);
					}
					
					btnDecrypt.addEventListener('click', attemptDecryption);
					passwordInput.addEventListener('keypress', (e) => {
						if (e.key === 'Enter') {
							attemptDecryption();
						}
					});
				});
			</script>
		)}
	</body>
</html>
